---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/sections/CTABand.astro';
import { asset, route } from '../lib/paths';
import { portraitImages, pricing } from '../content/data';

// Hero image
const heroImage = portraitImages[0];

// Photo strip above approach — 5 portraits, portrait_dancing moved to approach section
const stripImages = [
  portraitImages[9],  // woman-chair-studio
  portraitImages[10], // two-people-studio
  portraitImages[14], // woman-curly-window — centre slot
  portraitImages[12], // woman-window-bw-2
  portraitImages[13], // man-blue-jacket
];

// Gallery: first 9 portraits after the hero
const galleryImages = portraitImages.slice(1, 10);
---

<BaseLayout title="Home">

  {/* ══ HERO ══════════════════════════════════════════════════════════ */}
  <section class="hero">
    <div class="hero-content">
      <span class="eyebrow">Lafayette, IN · Urbana-Champaign, IL</span>
      <h1 class="hero-title">
        Portrait photography<br />
        <em>made with you, not for you.</em>
      </h1>
      <p class="hero-lead">
        I work with you to make something genuinely yours. My portrait photography
        is shaped by nature, street, and abstract photography — it's more about creating
        than recording. Personality over presentation.
      </p>
      <p class="hero-location">Lafayette, IN · Urbana-Champaign, IL · Sessions from $350.</p>
      <div class="btn-row">
        <a href={route('sessions/')} class="btn btn-primary btn-lg">See how it works</a>
        <a href={route('portfolio/')} class="btn btn-outline btn-lg">See some work</a>
      </div>
    </div>
    <div class="hero-image">
      <img
        src={asset(heroImage.src)}
        alt={heroImage.alt}
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>


  {/* ══ PHOTO STRIP ═══════════════════════════════════════════════════
      5 portraits in an asymmetric grid. portrait_dancing is the centre slot.
      Swap indices above (stripImages) to change which photos appear.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="photo-strip-section">
    <div class="photo-strip">
      {stripImages.map((img, i) => (
        <div class={`strip-item${i === 2 ? ' strip-featured' : ''}`}>
          <img
            src={asset(img.src)}
            alt={img.alt}
            loading="lazy"
            class="lightbox-trigger"
            data-src={asset(img.src)}
            data-alt={img.alt}
          />
        </div>
      ))}
    </div>
  </section>


  {/* ══ APPROACH ══════════════════════════════════════════════════════ */}
  <section class="section bg-soft">
    <div class="container">
      <div class="approach-split">
        <div class="stack">
          <span class="eyebrow">How I work</span>
          <h2>Collaboration over direction</h2>
          <p>
            Traditional portrait sessions are directed. You're told where to stand,
            how to angle your chin, when to smile. And?
          </p>
          <p class="approach-punch">The results look like portrait sessions.</p>
          <p>
            I come from nature, street, and abstract photography — work built through
            patience and attention rather than control. In a session, we're co-creating;
            I'm not directing. We talk before the camera comes out. We find a
            location that means something. We're making art shaped by your personality,
            not shaping your image to match a portrait ideal.
          </p>
          <a href={route('how-i-work/')} class="btn btn-outline" style="margin-top: var(--space-4);">More about my approach</a>
        </div>
        <div class="approach-image">
          <img src={asset(portraitImages[18].src)} alt={portraitImages[18].alt} loading="lazy" />
        </div>
      </div>
    </div>
  </section>


  {/* ══ PORTRAIT GALLERY ══════════════════════════════════════════════
      No heading — let the images speak. Click any to open lightbox.
      Change galleryImages slice above to show different portraits.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <div class="home-gallery">
        {galleryImages.map(img => (
          <div class="gallery-item">
            <img
              src={asset(img.src)}
              alt={img.alt}
              loading="lazy"
              class="lightbox-trigger"
              data-src={asset(img.src)}
              data-alt={img.alt}
            />
          </div>
        ))}
      </div>
      <div class="btn-row" style="margin-top: var(--space-6);">
        <a href={route('portfolio/portraits/')} class="btn btn-outline">All portrait work</a>
        <a href={route('portfolio/landscape/')} class="btn btn-ghost">Landscape &amp; abstract work</a>
      </div>
    </div>
  </section>


  {/* ══ PRICING ═══════════════════════════════════════════════════════ */}
  <section class="section bg-soft">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Sessions &amp; pricing</span>
        <h2>Two options. No surprises.</h2>
        <p class="lead" style="margin-top: 1rem;">
          Editing is included. Delivery is included. The price you see is what you pay.
        </p>
      </div>
      <div class="grid-2" style="margin-top: var(--space-7);">
        <div class="pricing-card">
          <div>
            <h6>{pricing.essential.name}</h6>
            <div class="pricing-amount" style="margin-top: var(--space-3);">
              <span>$</span>{pricing.essential.price}
            </div>
          </div>
          <ul class="pricing-features">
            {pricing.essential.features.map(f => <li>{f}</li>)}
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/')} class="btn btn-outline">Book this session</a>
          </div>
        </div>
        <div class="pricing-card featured">
          <div>
            <h6>{pricing.extended.name}</h6>
            <div class="pricing-amount" style="margin-top: var(--space-3);">
              <span>$</span>{pricing.extended.price}
            </div>
          </div>
          <ul class="pricing-features">
            {pricing.extended.features.map(f => <li>{f}</li>)}
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/')} class="btn btn-primary">Book this session</a>
          </div>
        </div>
      </div>
      <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-6);">
        Available in {pricing.travel.indianapolis.label} (+${pricing.travel.indianapolis.fee}) and {pricing.travel.chicago.label} (+${pricing.travel.chicago.fee}).
        <a href={route('sessions/')} style="color: var(--color-accent); text-decoration: underline; text-underline-offset: 2px;">Full details →</a>
      </p>
    </div>
  </section>


  {/* ══ CTA ═══════════════════════════════════════════════════════════ */}
  <CTABand
    eyebrow="Get in touch"
    heading="Let's start a conversation"
    body="Tell me what you're thinking — the ideas you have, what you want to explore, what you want to make. Then we can talk."
    primaryHref={route('contact/')}
    primaryLabel="Get in touch"
    secondaryHref={route('sessions/')}
    secondaryLabel="See sessions & pricing"
  />

</BaseLayout>


{/* ══ LIGHTBOX ══════════════════════════════════════════════════════
    Vanilla JS — no dependencies. Triggered by .lightbox-trigger imgs.
══════════════════════════════════════════════════════════════════ */}
<div id="lightbox" aria-modal="true" role="dialog" aria-label="Image lightbox">
  <button id="lightbox-close" aria-label="Close">&times;</button>
  <button id="lightbox-prev" aria-label="Previous">&#8592;</button>
  <button id="lightbox-next" aria-label="Next">&#8594;</button>
  <div id="lightbox-img-wrap">
    <img id="lightbox-img" src="" alt="" />
  </div>
</div>

<script>
  const lightbox = document.getElementById('lightbox')!;
  const lbImg    = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbClose  = document.getElementById('lightbox-close')!;
  const lbPrev   = document.getElementById('lightbox-prev')!;
  const lbNext   = document.getElementById('lightbox-next')!;

  const triggers = Array.from(document.querySelectorAll<HTMLImageElement>('.lightbox-trigger'));
  let current = 0;

  function open(index: number) {
    current = index;
    const img = triggers[current];
    lbImg.src = img.dataset.src || img.src;
    lbImg.alt = img.dataset.alt || img.alt;
    lightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
  }

  function prev() { open((current - 1 + triggers.length) % triggers.length); }
  function next() { open((current + 1) % triggers.length); }

  triggers.forEach((img, i) => img.addEventListener('click', () => open(i)));
  lbClose.addEventListener('click', close);
  lbPrev.addEventListener('click', prev);
  lbNext.addEventListener('click', next);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) close(); });
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') prev();
    if (e.key === 'ArrowRight') next();
  });
</script>


<style>
  /* ── Hero ────────────────────────────────────────────────────────── */
  .hero-location {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-top: var(--space-2);
    margin-bottom: var(--space-4);
  }

  /* ── Photo strip ─────────────────────────────────────────────────── */
  .photo-strip-section { overflow: hidden; }
  .photo-strip {
    display: grid;
    grid-template-columns: 1fr 1fr 1.5fr 1fr 1fr;
    gap: var(--space-2);
  }
  .strip-item {
    overflow: hidden;
    height: 440px;
  }
  .strip-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    cursor: pointer;
    transition: transform 0.3s ease;
    display: block;
  }
  .strip-item img:hover { transform: scale(1.03); }

  /* ── Approach split ──────────────────────────────────────────────── */
  .approach-split {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-10);
    align-items: center;
  }
  .approach-image { border-radius: var(--radius-lg); overflow: hidden; aspect-ratio: 4 / 5; }
  .approach-image img { width: 100%; height: 100%; object-fit: cover; }
  .approach-punch {
    font-size: var(--text-lg);
    font-weight: 500;
    font-style: italic;
  }

  /* ── Gallery ─────────────────────────────────────────────────────── */
  .home-gallery {
    columns: 3;
    column-gap: var(--space-3);
  }
  .gallery-item {
    break-inside: avoid;
    margin-bottom: var(--space-3);
    overflow: hidden;
    border-radius: var(--radius);
  }
  .gallery-item img {
    width: 100%;
    display: block;
    cursor: pointer;
    transition: transform 0.3s ease;
  }
  .gallery-item img:hover { transform: scale(1.02); }

  /* ── Lightbox ────────────────────────────────────────────────────── */
  #lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }
  #lightbox.open { display: flex; }
  #lightbox-img-wrap {
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius);
  }
  #lightbox-close {
    position: fixed;
    top: var(--space-4);
    right: var(--space-5);
    background: none;
    border: none;
    color: white;
    font-size: 2.5rem;
    cursor: pointer;
    line-height: 1;
    opacity: 0.8;
  }
  #lightbox-close:hover { opacity: 1; }
  #lightbox-prev,
  #lightbox-next {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    padding: var(--space-4);
    opacity: 0.7;
  }
  #lightbox-prev:hover, #lightbox-next:hover { opacity: 1; }
  #lightbox-prev { left: var(--space-4); }
  #lightbox-next { right: var(--space-4); }

  /* ── Responsive ──────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .photo-strip { grid-template-columns: 1fr 1fr; }
    .strip-item { height: 240px; }
    .strip-item:last-child { display: none; }

    .approach-split { grid-template-columns: 1fr; }
    .approach-image { aspect-ratio: 16 / 9; }

    .home-gallery { columns: 2; }
  }
</style>
