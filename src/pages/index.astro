---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PackageCard from '../components/PackageCard.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import FAQList from '../components/FAQList.astro';
import { getCollection } from 'astro:content';

const faqItems = [
  {
    question: 'What kinds of portrait sessions do you photograph?',
    answer:
      'Portrait sessions can be shaped for social media, creative self-expression, personal branding, editorial-feeling portraits, or collaborative art-making. I work with both individuals and businesses.'
  },
  {
    question: 'How is editing handled?',
    answer:
      'Every session includes professional-level editing — it\'s built into both packages, not a separate line item. The final images are polished, intentional, and ready to use.'
  },
  {
    question: 'Where do you work?',
    answer:
      'Zach is based in Lafayette, Indiana. Base pricing covers the Lafayette area and within 30 miles of Urbana-Champaign, Illinois. Indianapolis sessions add $100, Chicago sessions add $200.'
  }
];

const base = import.meta.env.BASE_URL;
const root = base.endsWith('/') ? base : `${base}/`;

const allItems = await getCollection('portfolio');

const featuredPortraits = allItems
  .filter((item) => item.data.category === 'collaborative' && item.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 1);

const featuredLandscapes = allItems
  .filter((item) => item.data.category === 'landscape' && item.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 1);

const portraitImageModules = import.meta.glob('../assets/portfolio/collaborative/*.{jpg,jpeg,png,webp}', {
  eager: true,
});

const landscapeImageModules = import.meta.glob('../assets/portfolio/landscape/*.{jpg,jpeg,png,webp}', {
  eager: true,
});

const portraitFeature = featuredPortraits
  .map((item) => {
    const key = `../assets/portfolio/collaborative/${item.data.coverImage}`;
    const mod = portraitImageModules[key] as { default?: { src?: string } };

    if (!mod?.default?.src) return null;

    return {
      title: item.data.title,
      alt: item.data.coverAlt,
      src: mod.default.src,
      text: item.body,
      href: `${root}portfolio/collaborative/`,
    };
  })
  .filter(Boolean)[0];

const landscapeFeature = featuredLandscapes
  .map((item) => {
    const key = `../assets/portfolio/landscape/${item.data.coverImage}`;
    const mod = landscapeImageModules[key] as { default?: { src?: string } };

    if (!mod?.default?.src) return null;

    return {
      title: item.data.title,
      alt: item.data.coverAlt,
      src: mod.default.src,
      text: item.body,
      href: `${root}portfolio/landscape/`,
    };
  })
  .filter(Boolean)[0];
---

<BaseLayout
  title="Zach Beauvais Photographer | Artistic Portrait Photography in Lafayette, Indiana"
  description="Collaborative portrait photography shaped by landscape photography and mixed-media art. Based in Lafayette, Indiana."
  path="/"
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Lafayette, Indiana photographer</p>
        <h1 class="h1">Collaborative portrait photography shaped by landscape and contemporary art.</h1>
        <p class="lead measure">
          I make portraits with people, not just of them. My work blends artistic portraiture with the visual language
          of landscape photography and mixed-media art to create images that feel expressive, intentional, and personal.
        </p>
        <ul class="meta-list" aria-label="Key details">
          <li>Portraits for self-expression</li>
          <li>Brand and professional imagery</li>
          <li>Edited delivery included</li>
        </ul>
        <div class="button-row">
          <a class="button button-primary" href={`${root}contact/`}>Book a session</a>
          <a class="button button-secondary" href={`${root}portfolio/collaborative/`}>View portrait portfolio</a>
        </div>
      </div>

      <div class="hero-image-panel">
        {portraitFeature ? (
          <img src={portraitFeature.src} alt={portraitFeature.alt} />
        ) : (
          <div class="hero-image-panel__placeholder" role="img" aria-label="Featured portrait placeholder"></div>
        )}
      </div>
    </div>
  </section>

  <section class="section surface-band">
    <div class="container stack">
      <SectionHeading
        eyebrow="Approach"
        title="Portrait sessions that leave room for collaboration, mood, and presence."
        intro="Whether the goal is a social profile, a brand refresh, or something more inward and exploratory, the process starts with conversation and ends with images that feel lived in rather than generic."
      />

      <div class="feature-grid">
        <div class="feature-item">
          <h3>Artistic collaboration</h3>
          <p>
            Sessions are guided, but not rigid. We can build around gesture, atmosphere, movement, styling, location,
            and the kind of story you want the images to hold.
          </p>
        </div>
        <div class="feature-item">
          <h3>Landscape-informed eye</h3>
          <p>
            My landscape background shapes how I work with light, weather, negative space, and environment. Even close
            portraits are built with a sense of place.
          </p>
        </div>
        <div class="feature-item">
          <h3>Mixed-media sensibility</h3>
          <p>
            I’m interested in texture, rhythm, contrast, and abstraction. That influence shows up in the way I frame,
            edit, and build a visual mood.
          </p>
        </div>
        <div class="feature-item">
          <h3>Professional editing included</h3>
          <p>
            Every package includes carefully edited final photographs so the work feels finished, cohesive, and ready to
            use or share.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="sessions">
    <div class="container stack">
      <SectionHeading
        eyebrow="Portrait sessions"
        title="Simple packages. Everything edited and included."
        intro="Two portrait packages cover most needs. Base pricing covers the Lafayette, Indiana area and within 30 miles of Urbana-Champaign, Illinois."
      />

      <div class="package-grid">
        <PackageCard
          name="Single-location session"
          price="$350"
          description="A focused session for concise portraits, refreshed social imagery, or a collaborative short concept."
          items={[
            '1 hour',
            '1 location',
            '5 professionally edited portraits',
            'All editing included'
          ]}
        />
        <PackageCard
          name="Extended portrait session"
          price="$750"
          description="More time, more variation, and more room to explore a fuller visual idea across lighting, styling, and mood."
          items={[
            '3 hours',
            '1 location',
            '20 professionally edited photos',
            'All editing included'
          ]}
        />
      </div>

      <div class="note-card">
        <h3>Travel</h3>
        <p class="measure">
          Base pricing covers Lafayette, Indiana and the Urbana-Champaign, Illinois area.
          Indianapolis and Chicago available for an additional fee.
        </p>
        <ul class="location-list" aria-label="Travel fees">
          <li>Indianapolis — add $100 per session</li>
          <li>Chicago — add $200 per session</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section surface-band">
    <div class="container stack">
      <SectionHeading
        eyebrow="Portfolio"
        title="Two bodies of work, one visual language."
        intro="Collaborative portrait work alongside landscape and abstract photography — both feed the same eye for light, atmosphere, and presence."
      />

      <div class="portfolio-highlight-grid portfolio-highlight-grid--images">
        <a class="portfolio-feature-card" href={`${root}portfolio/collaborative/`}>
          {portraitFeature ? (
            <img class="portfolio-feature-card__image" src={portraitFeature.src} alt={portraitFeature.alt} loading="lazy" />
          ) : (
            <div class="portfolio-feature-card__placeholder" aria-hidden="true"></div>
          )}
          <div class="portfolio-feature-card__body">
            <h3>Collaborative / expressive portraits</h3>
            <p>
              {portraitFeature?.text ??
                'Portrait work centred on mood, collaboration, and the expressive possibilities of light, gesture, and place.'}
            </p>
            <span class="portfolio-feature-card__cta">See portrait portfolio</span>
          </div>
        </a>

        <a class="portfolio-feature-card" href={`${root}portfolio/landscape/`}>
          {landscapeFeature ? (
            <img class="portfolio-feature-card__image" src={landscapeFeature.src} alt={landscapeFeature.alt} loading="lazy" />
          ) : (
            <div class="portfolio-feature-card__placeholder" aria-hidden="true"></div>
          )}
          <div class="portfolio-feature-card__body">
            <h3>Landscape / abstract</h3>
            <p>
              {landscapeFeature?.text ??
                'Landscape and abstract work that feeds the sensibility behind the portrait practice: atmosphere, structure, and visual tension.'}
            </p>
            <span class="portfolio-feature-card__cta">See landscape &amp; abstract</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container stats-grid">
      <article class="stat-card">
        <p class="stat-value">2</p>
        <p class="stat-label">Portrait packages</p>
        <p>Clear session options without an overloaded pricing menu.</p>
      </article>
      <article class="stat-card">
        <p class="stat-value">2</p>
        <p class="stat-label">Travel cities</p>
        <p>Indianapolis and Chicago available beyond the Lafayette and Urbana-Champaign base area.</p>
      </article>
      <article class="stat-card">
        <p class="stat-value">5–20</p>
        <p class="stat-label">Edited images</p>
        <p>Enough range for either a focused session or a more expansive story.</p>
      </article>
      <article class="stat-card">
        <p class="stat-value">1–3 hrs</p>
        <p class="stat-label">Session length</p>
        <p>Flexible enough for either focused portraits or deeper collaborative work.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <SectionHeading
        eyebrow="FAQ"
        title="A few practical details."
      />
      <FAQList items={faqItems} />
    </div>
  </section>

  <section class="section-tight">
    <div class="container cta-panel stack">
      <p class="eyebrow" style="color: rgba(253,252,251,0.72)">Get in touch</p>
      <h2>Interested in making something together?</h2>
      <p class="measure">
        Tell me what you want the images to do: update your presence, support your work, or explore something more
        personal. I’m also on Instagram at <a href="https://instagram.com/zach_of_the" target="_blank" rel="noopener noreferrer">@zach_of_the</a>.
      </p>
      <div class="button-row">
        <a class="button button-secondary" href={`${root}contact/`}>Start a booking inquiry</a>
        <a class="button button-secondary" href="https://instagram.com/zach_of_the" target="_blank" rel="noopener noreferrer">Visit Instagram</a>
      </div>
    </div>
  </section>
</BaseLayout>