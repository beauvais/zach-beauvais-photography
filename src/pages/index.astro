---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/sections/CTABand.astro';
import { asset, route } from '../lib/paths';
import { portraitImages, landscapeImages, pricing } from '../content/data';

// Images shown in the homepage portfolio preview (first 4 portraits after the hero)
const previewPortraits = portraitImages.slice(1, 5);
// Images shown in the landscape teaser (first 3 landscape images)
const landscapePreview = landscapeImages.slice(0, 3);
---

<BaseLayout title="Home">

  {/* ══ HERO ══════════════════════════════════════════════════════════
      Edit: headline, subheading, hero image, button labels and links.
      Hero image is the first portrait in portraitImages (data.ts).
  ══════════════════════════════════════════════════════════════════ */}
  <section class="hero">
    <div class="hero-content">
      <span class="eyebrow">Lafayette, Indiana | Urbana-Champaign, Illinois</span>
      <h1 class="hero-title">
        Portraits to<br />
        <em>find your story</em>
      </h1>
      <p class="hero-lead">
        Collaborative, creative portrait photography for people, brands, and moments
        worth retelling. Rooted in storytelling, shaped by art.
      </p>
      <div class="btn-row">
        <a href={route('sessions/')} class="btn btn-primary btn-lg">Sessions</a>
        <a href={route('portfolio/')} class="btn btn-outline btn-lg">Work</a>
      </div>
    </div>
    <div class="hero-image">
      <img
        src={asset(portraitImages[0].src)}
        alt={portraitImages[0].alt}
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>


  {/* ══ APPROACH ══════════════════════════════════════════════════════
      Edit: section heading, intro text, and the four feature items.
      To hide this section, wrap it in a comment: {/* <section>...</section> *\/}
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section bg-soft">
    <div class="container">
      <div class="section-header" style="max-width: 50rem;">
        <span class="eyebrow">The approach</span>
        <h2>Photography as collaboration</h2>
        <p class="lead" style="margin-top: 1rem;">
          Every portrait session begins with a conversation. I bring a storyteller's eye and
          an artist's sensibility — you bring yourself. Together we make something that's
          genuinely yours.
        </p>
      </div>
      <div class="grid-4" style="margin-top: var(--space-8);">
        <div>
          <span class="feature-number eyebrow" style="margin-bottom: var(--space-3);">01</span>
          <h5>Tell me about you</h5>
          <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-2);">
            Before any camera comes out, we discuss what you want to accomplish. We'll talk goals, inspiration, and direction; but mostly, we'll talk about you.
          </p>
        </div>
        <div>
          <span class="feature-number eyebrow" style="margin-bottom: var(--space-3);">02</span>
          <h5>Location matters</h5>
          <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-2);">
            We choose a location that reflects your personality — a studio, your home,
            a favourite spot outdoors. Setting is part of the story.
          </p>
        </div>
        <div>
          <span class="feature-number eyebrow" style="margin-bottom: var(--space-3);">03</span>
          <h5>Natural, unhurried</h5>
          <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-2);">
            Sessions are relaxed and flexible. I work to put you at ease so the images
            feel authentic, not staged.
          </p>
        </div>
        <div>
          <span class="feature-number eyebrow" style="margin-bottom: var(--space-3);">04</span>
          <h5>Professional editing</h5>
          <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-2);">
            Every delivered image is professionally edited. The final photos are ready
            to use — no further work required.
          </p>
        </div>
      </div>
    </div>
  </section>


  {/* ══ PORTFOLIO PREVIEW ═════════════════════════════════════════════
      Shows 1 large portrait + 4 thumbnail grid.
      Images come from portraitImages in data.ts (indices 1–4).
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Selected work</span>
        <h2>Recent portraits</h2>
      </div>
      <div class="home-gallery">
        <div class="home-gallery-main">
          <img src={asset(previewPortraits[0].src)} alt={previewPortraits[0].alt} loading="lazy" />
        </div>
        <div class="home-gallery-grid">
          {previewPortraits.slice(1).map(img => (
            <img src={asset(img.src)} alt={img.alt} loading="lazy" />
          ))}
        </div>
      </div>
      <div class="btn-row" style="margin-top: var(--space-6);">
        <a href={route('portfolio/portraits/')} class="btn btn-outline">All portraits</a>
        <a href={route('portfolio/landscape/')} class="btn btn-ghost">Landscape &amp; art</a>
      </div>
    </div>
  </section>


  {/* ══ PRICING ═══════════════════════════════════════════════════════
      Prices come from pricing in data.ts — edit there, not here.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section bg-soft">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Sessions &amp; pricing</span>
        <h2>Simple, transparent pricing</h2>
        <p class="lead" style="margin-top: 1rem;">
          Two session formats, both all-inclusive — editing, delivery, no hidden fees.
        </p>
      </div>
      <div class="grid-2" style="margin-top: var(--space-7);">
        <div class="pricing-card">
          <div>
            <h6>{pricing.essential.name}</h6>
            <div class="pricing-amount" style="margin-top: var(--space-3);">
              <span>$</span>{pricing.essential.price}
            </div>
          </div>
          <ul class="pricing-features">
            {pricing.essential.features.map(f => <li>{f}</li>)}
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/')} class="btn btn-outline">Book this session</a>
          </div>
        </div>
        <div class="pricing-card featured">
          <div>
            <h6>{pricing.extended.name}</h6>
            <div class="pricing-amount" style="margin-top: var(--space-3);">
              <span>$</span>{pricing.extended.price}
            </div>
          </div>
          <ul class="pricing-features">
            {pricing.extended.features.map(f => <li>{f}</li>)}
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/')} class="btn btn-primary">Book this session</a>
          </div>
        </div>
      </div>
      <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-6);">
        Available in {pricing.travel.indianapolis.label} (+${pricing.travel.indianapolis.fee}) and {pricing.travel.chicago.label} (+${pricing.travel.chicago.fee}).
        <a href={route('sessions/')} style="color: var(--color-accent); text-decoration: underline; text-underline-offset: 2px;">Full details →</a>
      </p>
    </div>
  </section>


  {/* ══ ABOUT SNIPPET ════════════════════════════════════════════════
      Image on left, bio text on right. Edit text inline below.
      Image: couple.jpg from portfolio/
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split-image">
          <img src={asset('couple.jpg')} alt="Collaborative portrait work" loading="lazy" />
        </div>
        <div class="stack">
          <span class="eyebrow">About Zach</span>
          <h2>A storyteller with a camera</h2>
          <p>
            My background is in storytelling and nature photography — I came to portraits with
            a documentary eye and an artist's instinct for atmosphere. I'm interested in what
            makes you <em>you</em>: the way light catches your expression, the story that lives
            in a glance.
          </p>
          <p>
            Every portrait session is a collaboration. I work with you, not just at you.
          </p>
          <a href={route('about/')} class="btn btn-outline">More about me</a>
        </div>
      </div>
    </div>
  </section>


  {/* ══ LANDSCAPE TEASER ══════════════════════════════════════════════
      3-image preview of landscape/abstract work.
      Images come from landscapeImages in data.ts (first 3).
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section bg-strong">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Beyond portraits</span>
        <h2>Landscape &amp; abstract work</h2>
        <p class="lead" style="margin-top: 1rem;">
          The same eye I bring to portraiture — attention to light, texture, and mood —
          applied to the natural and abstract world.
        </p>
      </div>
      <div class="landscape-preview">
        {landscapePreview.map(img => (
          <img src={asset(img.src)} alt={img.alt} loading="lazy" />
        ))}
      </div>
      <div style="margin-top: var(--space-6);">
        <a href={route('portfolio/landscape/')} class="btn btn-outline">Explore landscape &amp; art</a>
      </div>
    </div>
  </section>


  {/* ══ CTA ═══════════════════════════════════════════════════════════
      Edit text via props below. Href values use route() for base-path safety.
  ══════════════════════════════════════════════════════════════════ */}
  <CTABand
    eyebrow="Ready when you are"
    heading="Let's make something together"
    body="Whether it's for a special event, your personal brand, or just because you deserve a great portrait — reach out and let's talk about what you have in mind."
    primaryHref={route('contact/')}
    primaryLabel="Get in touch"
    secondaryHref={route('sessions/')}
    secondaryLabel="See pricing"
  />

</BaseLayout>

<style>
  .home-gallery {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-3);
    align-items: start;
  }
  .home-gallery-main { border-radius: var(--radius-lg); overflow: hidden; aspect-ratio: 3 / 4; }
  .home-gallery-main img { width: 100%; height: 100%; object-fit: cover; }
  .home-gallery-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); }
  .home-gallery-grid img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: var(--radius); }

  .landscape-preview { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); margin-top: var(--space-7); }
  .landscape-preview img { width: 100%; aspect-ratio: 3 / 4; object-fit: cover; border-radius: var(--radius-lg); }

  @media (max-width: 768px) {
    .home-gallery { grid-template-columns: 1fr; }
    .home-gallery-main { aspect-ratio: 16 / 9; }
    .landscape-preview { grid-template-columns: repeat(2, 1fr); }
    .landscape-preview img:last-child { display: none; }
  }
</style>
