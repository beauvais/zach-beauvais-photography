---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allItems = await getCollection('portfolio');

const featuredPortraits = allItems
  .filter((item) => item.data.category === 'collaborative' && item.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const featuredLandscapes = allItems
  .filter((item) => item.data.category === 'landscape' && item.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const portraitImageModules = import.meta.glob('../assets/portfolio/collaborative/*.{jpg,jpeg,png,webp}', {
  eager: true,
});

const landscapeImageModules = import.meta.glob('../assets/portfolio/landscape/*.{jpg,jpeg,png,webp}', {
  eager: true,
});

const portraitCards = featuredPortraits
  .map((item) => {
    const key = `../assets/portfolio/collaborative/${item.data.coverImage}`;
    const mod = portraitImageModules[key] as { default?: { src?: string } };

    if (!mod?.default?.src) return null;

    return {
      title: item.data.title,
      alt: item.data.coverAlt,
      src: mod.default.src,
      text: item.body,
      href: `${import.meta.env.BASE_URL}portfolio/collaborative/`,
    };
  })
  .filter(Boolean);

const landscapeCards = featuredLandscapes
  .map((item) => {
    const key = `../assets/portfolio/landscape/${item.data.coverImage}`;
    const mod = landscapeImageModules[key] as { default?: { src?: string } };

    if (!mod?.default?.src) return null;

    return {
      title: item.data.title,
      alt: item.data.coverAlt,
      src: mod.default.src,
      text: item.body,
      href: `${import.meta.env.BASE_URL}portfolio/landscape/`,
    };
  })
  .filter(Boolean);

const featuredWork = [...portraitCards, ...landscapeCards].slice(0, 6);

const base = import.meta.env.BASE_URL;
const root = base.endsWith('/') ? base : `${base}/`;
---

<BaseLayout
  title="Zach Beauvais Photographer"
  description="Collaborative portrait photography in Lafayette, Indiana, with sessions also available in Indianapolis, Urbana-Champaign, and Chicago."
>
  <section class="home-hero container">
    <div class="home-hero__copy">
      <p class="eyebrow">Zach Beauvais Photographer</p>
      <h1>Collaborative portrait photography with an artistic, contemporary approach.</h1>
      <p class="lede">
        Portrait sessions that blend artistic portraiture with the visual language of landscape and
        contemporary art.
      </p>
      <p>
        Based in Lafayette, Indiana. Available for portrait sessions in Lafayette, Indianapolis,
        Urbana-Champaign, and Chicago.
      </p>

      <div class="home-hero__actions">
        <a class="button-primary" href={`${root}contact/`}>Book a Session</a>
        <a class="button-secondary" href={`${root}portfolio/collaborative/`}>View Portrait Portfolio</a>
      </div>
    </div>

    <div class="home-hero__details">
      <div class="home-detail-card">
        <h2>Portrait sessions</h2>
        <ul class="home-detail-list">
          <li>Social media portraits</li>
          <li>Brand and professional portraits</li>
          <li>Self-expression and personal exploration</li>
        </ul>
      </div>

      <div class="home-detail-card">
        <h2>Pricing</h2>
        <ul class="home-detail-list">
          <li>1 hour / 1 location / 5 edited photos — $350</li>
          <li>3 hours / 25 edited photos — $750</li>
          <li>Indianapolis, Urbana-Champaign, or Chicago — +$150</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="home-section container">
    <div class="home-section__intro">
      <p class="eyebrow">Approach</p>
      <h2>Portraits made collaboratively, not just captured.</h2>
    </div>

    <div class="home-two-column">
      <p>
        My portrait work is shaped by a background in international landscape photography and
        mixed-media art. That influence carries into the way I work with people: attentive to mood,
        place, gesture, texture, and the feeling an image leaves behind.
      </p>
      <p>
        Whether you need portraits for your creative practice, your professional identity, your
        brand, or your own self-exploration, the aim is to make images that feel thoughtful,
        distinctive, and genuinely like you.
      </p>
    </div>
  </section>

  <section class="home-section container">
    <div class="home-section__intro">
      <p class="eyebrow">Featured Work</p>
      <h2>Selected images from portrait and landscape work.</h2>
    </div>

    <div class="home-featured-grid">
      {featuredWork.map((item) => (
        <a class="home-featured-card" href={item.href}>
          <img src={item.src} alt={item.alt} loading="lazy" />
          <div class="home-featured-card__body">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="home-section container">
    <div class="home-section__intro">
      <p class="eyebrow">Sessions</p>
      <h2>Simple, transparent session options.</h2>
    </div>

    <div class="home-pricing-grid">
      <article class="home-pricing-card">
        <h3>Short Session</h3>
        <p class="home-price">$350</p>
        <ul class="home-detail-list">
          <li>1 hour</li>
          <li>1 location</li>
          <li>5 professionally edited photographs</li>
        </ul>
      </article>

      <article class="home-pricing-card">
        <h3>Extended Session</h3>
        <p class="home-price">$750</p>
        <ul class="home-detail-list">
          <li>3 hours</li>
          <li>25 professionally edited photographs</li>
          <li>Professional-level editing included</li>
        </ul>
      </article>
    </div>

    <p class="home-note">
      Travel to Indianapolis, Urbana-Champaign, or Chicago is available for an additional $150.
    </p>
  </section>

  <section class="home-section container">
    <div class="home-section__intro">
      <p class="eyebrow">Portfolio</p>
      <h2>Two strands of work, one visual approach.</h2>
    </div>

    <div class="home-links-grid">
      <a class="home-link-card" href={`${root}portfolio/collaborative/`}>
        <h3>Collaborative Portraits</h3>
        <p>Expressive portrait work shaped by collaboration, atmosphere, and visual storytelling.</p>
      </a>

      <a class="home-link-card" href={`${root}portfolio/landscape/`}>
        <h3>Landscape &amp; Abstract</h3>
        <p>Landscape and abstract work rooted in observation, structure, texture, and place.</p>
      </a>
    </div>
  </section>

  <section class="home-cta container">
    <div>
      <p class="eyebrow">Book</p>
      <h2>Interested in making something together?</h2>
      <p>
        I’m based in Lafayette and available for sessions locally or in nearby cities. You can also
        find more work on Instagram at
        <a href="https://instagram.com/zach_of_the" target="_blank" rel="noreferrer noopener">@zach_of_the</a>.
      </p>
    </div>

    <div class="home-cta__actions">
      <a class="button-primary" href={`${root}contact/`}>Get in Touch</a>
      <a class="button-secondary" href="https://instagram.com/zach_of_the" target="_blank" rel="noreferrer noopener">
        Follow on Instagram
      </a>
    </div>
  </section>
</BaseLayout>