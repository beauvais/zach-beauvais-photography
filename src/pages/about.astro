---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="Zach Beauvais is a collaborative portrait photographer based in Lafayette, Indiana, with a background in storytelling and nature photography."
>
  <!-- ─── Page Header ───────────────────────────────────────────────── -->
  <section class="page-header">
    <div class="container">
      <span class="eyebrow">About</span>
      <h1>Zach Beauvais</h1>
      <p class="lead" style="margin-top: var(--space-4);">
        Photographer. Storyteller. Based in Lafayette, Indiana.
      </p>
    </div>
  </section>

  <!-- ─── Bio ──────────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="about-split">
        <div class="about-image">
          <img src="/portrait-7.jpg" alt="Zach Beauvais — photographer" loading="lazy" />
        </div>

        <div class="about-bio stack">
          <h2>A collaborative approach to portrait photography</h2>

          <p>
            I came to portrait photography through storytelling and the natural world. My early work
            was in nature and abstract photography — learning to read light, to find the image that
            already existed rather than imposing one. That sensibility shapes everything I do now.
          </p>

          <p>
            When I photograph people, I'm interested in the same things: atmosphere, authenticity,
            the way a moment can hold a whole personality. A portrait should feel like the person
            in it, not like a photograph of them.
          </p>

          <p>
            The word <em>collaborative</em> matters to me. I don't direct sessions — I
            facilitate them. We figure out together what feels right, what setting resonates,
            what story we're telling. My job is to be ready when it happens.
          </p>

          <p>
            I work with individuals, couples, families, and small businesses. Whether you need
            portraits for your professional brand, for a special occasion, or simply because
            you've never had a photograph you truly love — I'd like to help with that.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Pull Quote ────────────────────────────────────────────────── -->
  <section class="section-sm bg-soft">
    <div class="container-narrow">
      <blockquote class="pull-quote">
        "A portrait should feel like the person in it — not like a photograph of them."
      </blockquote>
    </div>
  </section>

  <!-- ─── Background ───────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="grid-2" style="align-items: start; gap: var(--space-10);">
        <div class="stack">
          <span class="eyebrow">Background</span>
          <h3>From nature to narrative</h3>
          <p>
            My photography practice began outdoors — in forests, along coastlines, in the
            abstract textures of weathered surfaces and winter light. Learning to see in those
            environments taught me patience, attentiveness, and the discipline of waiting for
            the image rather than forcing it.
          </p>
          <p>
            That documentary, observational approach carries directly into portrait work.
            I'm not looking to create a fantasy version of you. I'm looking for the real one —
            the version that exists in the right light, with the right space, given a little time.
          </p>
        </div>

        <div class="stack">
          <span class="eyebrow">Who I work with</span>
          <h3>Individuals &amp; small businesses</h3>
          <p>
            My sessions suit people who want portraits that are a little different: personal,
            considered, genuinely collaborative. I work well with people who might feel
            uncomfortable in front of a camera — part of my approach is making that feeling go away.
          </p>
          <p>
            I also work with small businesses and brands that want visually beautiful imagery
            to express their identity — the kind of photography that tells a story rather than
            just filling a slot.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Abstract sample ──────────────────────────────────────────── -->
  <section class="section bg-strong">
    <div class="container">
      <div class="abstract-trio">
        <img src="/abstract_close.jpg" alt="Abstract photography — texture study" loading="lazy" />
        <img src="/flower.jpg" alt="Nature photography" loading="lazy" />
        <img src="/abstract_portrait.jpg" alt="Abstract study" loading="lazy" />
      </div>
      <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-4);">
        A selection of landscape and abstract work — the visual sensibility that underpins the portrait sessions.
      </p>
    </div>
  </section>

  <!-- ─── Location ─────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Location &amp; availability</span>
        <h2>Based in Lafayette, Indiana</h2>
      </div>

      <div class="grid-3" style="margin-top: var(--space-7);">
        <div class="card card-soft">
          <div class="card-body">
            <h6>Lafayette &amp; Urbana-Champaign</h6>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              Sessions within 30 miles at standard pricing — $350 (1 hr) or $750 (3 hrs).
            </p>
          </div>
        </div>
        <div class="card card-soft">
          <div class="card-body">
            <h6>Indianapolis</h6>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              All sessions available with an additional $100 travel fee per session.
            </p>
          </div>
        </div>
        <div class="card card-soft">
          <div class="card-body">
            <h6>Chicago</h6>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              All sessions available with an additional $200 travel fee per session.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CTA ──────────────────────────────────────────────────────── -->
  <section class="cta-band">
    <div class="container-narrow">
      <span class="eyebrow">Work together</span>
      <h2>Ready to make your portrait?</h2>
      <p>
        I'd love to hear what you have in mind. Get in touch and let's start the conversation.
      </p>
      <div class="btn-row" style="justify-content: center;">
        <a href="/contact/" class="btn btn-accent btn-lg">Get in touch</a>
        <a href="/sessions/" class="btn btn-ghost btn-lg" style="color: rgba(253,252,251,0.7);">See sessions &amp; pricing</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-split {
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  .about-image {
    position: sticky;
    top: 6rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .about-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-bio {
    padding-top: var(--space-3);
  }

  .abstract-trio {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  .abstract-trio img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  @media (max-width: 768px) {
    .about-split {
      grid-template-columns: 1fr;
    }

    .about-image {
      position: static;
      aspect-ratio: 16 / 9;
    }

    .abstract-trio {
      grid-template-columns: 1fr 1fr;
    }

    .abstract-trio img:last-child {
      display: none;
    }
  }
</style>
