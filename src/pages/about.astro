---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/sections/CTABand.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import { asset, route } from '../lib/paths';
import { site, pricing } from '../content/data';

const personSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": site.name,
  "jobTitle": "Portrait Photographer",
  "worksFor": {
    "@type": "LocalBusiness",
    "name": site.title,
    "url": Astro.site?.toString()
  },
  "url": new URL('/about', Astro.site).toString(),
  "sameAs": [site.instagramUrl]
});
---

<BaseLayout
  title="About"
  description={`${site.name} is a portrait photographer based in Lafayette, IN and Urbana-Champaign, IL. A background in nature and abstract photography shapes an observational, collaborative approach to portrait work.`}
  schema={personSchema}
>

  {/* ══ PAGE HEADER ══════════════════════════════════════════════════ */}
  <section class="page-header">
    <div class="container">
      <span class="eyebrow">About</span>
      <h1>{site.name}</h1>
      <p class="lead" style="margin-top: var(--space-4);">
        Portrait photographer. Based in Lafayette, IN and Urbana-Champaign, IL.
      </p>
    </div>
  </section>


  {/* ══ BIO ═══════════════════════════════════════════════════════════
      Image is sticky on desktop. Edit paragraphs below.
      To swap the photo: change 'zach_beauvais-photographer.jpg' to another filename.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <div class="portrait-split">
        <div class="split-image about-image">
          <img src={asset('zach_beauvais-photographer.jpg')} alt="Zach Beauvais — photographer" width="3825" height="4781" loading="lazy" />
        </div>
        <div class="stack">
          <h2>From the outdoors in</h2>
          <p>
            I learned to shoot on my dad's Minolta — a 35mm film SLR he'd had since before I was born.
I photographed Colorado mountains, desert, flowers, wildlife. Things that are entirely themselves
and don't perform for the camera.
          </p>
          <p>
            I kept taking photos, grateful that I'd learned on film but excited by the flexibility of
            digital. I made photos of nature, then explored street photography by finding
            interesting frames and pools of light. At some point, I realised I'd been making
            portraits all along — portraits of flowers and hills, trees and occasionally sheep.
          </p>
          <p>
            Working with people followed naturally. And I bring a background in marketing,
            UX, and brand along with the camera — so I can think about what an image
            needs to do, not just how it looks.
          </p>
          <p>
            I'm based in the Lafayette and West Lafayette area of Indiana, and Urbana-Champaign, Illinois.
          </p>
        </div>
      </div>
    </div>
  </section>


  {/* ══ PULL QUOTE ════════════════════════════════════════════════════
      Edit the quote text below.
      To hide: wrap in {/* ... *\/}
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section-sm bg-soft">
    <div class="container-narrow">
      <blockquote class="pull-quote">
        "My job isn't to be the chap with a camera, but to make art with and about you"
      </blockquote>
    </div>
  </section>


  {/* ══ ABSTRACT WORK SAMPLE ══════════════════════════════════════════
      3-image row from landscape/abstract work.
      To swap images: change the filenames below (files live in /portfolio/).
      To hide: wrap the section in {/* ... *\/}
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section bg-strong">
    <div class="container">
      <div class="abstract-trio">
        <div class="abstract-trio-item"><img src={asset('abstract/abstract_close.jpg')}    alt="Abstract photography — texture study" width="1600" height="2000" loading="lazy" /></div>
        <div class="abstract-trio-item"><img src={asset('abstract/abstract_snow.jpg')}      alt="Abstract winter light study"          width="2000" height="1600" loading="lazy" /></div>
        <div class="abstract-trio-item"><img src={asset('abstract/abstract_portrait.jpg')} alt="Abstract study"                       width="1330" height="2000" loading="lazy" /></div>
      </div>
      <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-4);">
        A selection of landscape and abstract work that informs the portraits I make.
      </p>
    </div>
  </section>


  {/* ══ LOCATION CARDS ════════════════════════════════════════════════
      Travel fees come from pricing.travel in data.ts.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Location &amp; availability</span>
        <h2>Based in {site.location}</h2>
      </div>
      <div class="grid-3" style="margin-top: var(--space-7);">
        <div class="card card-soft">
          <div class="card-body">
            <h6>Lafayette &amp; Urbana-Champaign</h6>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              Sessions within 30 miles at standard pricing — ${pricing.essential.price} ({pricing.essential.hours} hr) or ${pricing.extended.price} ({pricing.extended.hours} hrs).
            </p>
          </div>
        </div>
        <div class="card card-soft">
          <div class="card-body">
            <h6>{pricing.travel.indianapolis.label}</h6>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              All sessions available with an additional ${pricing.travel.indianapolis.fee} travel fee per session.
            </p>
          </div>
        </div>
        <div class="card card-soft">
          <div class="card-body">
            <h6>{pricing.travel.chicago.label}</h6>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              All sessions available with an additional ${pricing.travel.chicago.fee} travel fee per session.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>


  {/* ══ TESTIMONIALS ══════════════════════════════════════════════════ */}
  <Testimonials variant="about" />


  {/* ══ CTA ═══════════════════════════════════════════════════════════ */}
  <CTABand
    eyebrow="Work together"
    heading="Let's start a conversation"
    body="Get in touch and we'll figure out what feels right."
    primaryHref={route('contact/')}
    primaryLabel="Get in touch"
    secondaryHref={route('sessions/')}
    secondaryLabel="See sessions &amp; pricing"
  />

</BaseLayout>

<style>
  /* Sticky image — behaviour specific to this page's long bio layout */
  .about-image { position: sticky; top: 6rem; }

  /* Abstract trio — used only on this page */
  .abstract-trio { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); }
  .abstract-trio-item { aspect-ratio: 4 / 3; overflow: hidden; border-radius: var(--radius-lg); }
  .abstract-trio-item img { width: 100%; height: 100%; object-fit: cover; display: block; }

  @media (max-width: 960px) {
    .about-image { position: static; aspect-ratio: 16 / 9; }
    .abstract-trio { grid-template-columns: 1fr 1fr; }
    .abstract-trio-item:last-child { display: none; }
  }
</style>
