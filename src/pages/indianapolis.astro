---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/sections/CTABand.astro';
import { asset, route } from '../lib/paths';
import { pricing, portraitImages } from '../content/data';

const essentialPrice = pricing.essential.price + pricing.travel.indianapolis.fee;
const explorationPrice = pricing.extended.price + pricing.travel.indianapolis.fee;

const faqData = [
  {
    q: "Is the travel fee already included in the Indianapolis prices?",
    a: "Yes. The prices shown on this page already include the Indianapolis travel fee. What you see is what you pay — no additions at booking."
  },
  {
    q: "Where do Indianapolis sessions typically take place?",
    a: "Fountain Square, Mass Ave, Broad Ripple, the Canal — Indy has a lot of good neighbourhoods to work in. We'd talk beforehand and find what fits the portrait, not just what's convenient."
  },
  {
    q: "Is parking straightforward in Indianapolis?",
    a: "Depends on the neighbourhood, but generally yes — street parking or a nearby lot usually works fine. I factor in ease of access when we're talking through location options."
  }
];

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Zach Beauvais Photography",
  "description": "Portrait photography in Indianapolis, Indiana. Collaborative sessions for individuals, families, and small businesses. Travel included in price.",
  "url": "https://zachbeauvais.com/indianapolis/",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Indianapolis",
    "addressRegion": "IN",
    "addressCountry": "US"
  },
  "areaServed": ["Indianapolis", "Central Indiana", "Indiana"],
  "priceRange": `$${essentialPrice}–$${explorationPrice}`
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a }
  }))
};

const schema = JSON.stringify([localBusiness, faqSchema]);
---

<BaseLayout
  title="Portrait Photographer in Indianapolis, Indiana"
  description={`Portrait photography in Indianapolis — $${essentialPrice} and up, travel included. Collaborative sessions for individuals, families, and small businesses across Indy and Central Indiana.`}
  schema={schema}
>

  {/* ══ PAGE HEADER ══════════════════════════════════════════════════ */}
  <section class="page-header">
    <div class="container">
      <span class="eyebrow">Portrait photographer</span>
      <h1>Indianapolis, Indiana.</h1>
      <p class="lead" style="margin-top: var(--space-4); max-width: 52ch;">
        Portrait sessions in Indianapolis, with travel included in the price.
        Same approach as always — just an hour further south.
      </p>
    </div>
  </section>


  {/* ══ THE APPROACH ══════════════════════════════════════════════════
      Split: text left, portrait right.
      [13] man-blue-jacket — industrial space, movement — urban register.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section bg-strong">
    <div class="container">
      <div class="approach-split">
        <div class="stack">
          <p>
            I'm based in Lafayette — an hour up I-65 — and I work in Indianapolis regularly.
            It's a proper city: good light, good architecture, neighbourhoods worth working in.
          </p>
          <p>
            Same approach as everywhere else. We talk before we start. We figure out what the
            portrait is for and who it's of. We find a location that fits that, not one that's
            just convenient. Then we work.
          </p>
        </div>
        <div class="approach-image">
          <img
            src={asset(portraitImages[13].src)}
            alt={portraitImages[13].alt}
            width={portraitImages[13].width}
            height={portraitImages[13].height}
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>


  {/* ══ WHO THIS IS FOR ═══════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <span class="eyebrow">Good for</span>
      <h2>Individuals, families, and Indy businesses</h2>
      <div class="who-grid">
        <p>
          Indianapolis has a bigger professional pool than Lafayette — more people building brands,
          more small businesses that need imagery that looks like them rather than like a stock
          library. That's most of what I do there.
        </p>
        <p>
          Families and individuals too. Milestone portraits, personal projects, couples who want
          something more considered than a posed shot in front of a monument.
        </p>
        <p>
          Whatever brings you here: same conversation, same care, same result. The city changes.
          The work doesn't.
        </p>
      </div>
    </div>
  </section>


  {/* ══ PHOTO STRIP ═══════════════════════════════════════════════════
      [11] woman-purple-hair  — rough wall, urban texture
      [6]  man-window-colour  — industrial window, colour
      [3]  woman-softlight    — soft window light, personal
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section-sm bg-strong">
    <div class="container">
      <div class="strip-masonry">
        <div class="strip-masonry-item">
          <a
            href={asset(portraitImages[11].src)}
            data-pswp-width={portraitImages[11].width}
            data-pswp-height={portraitImages[11].height}
            data-pswp-id={portraitImages[11].src.split('/').pop()?.replace(/\.[^.]+$/, '').toLowerCase()}
            class="pswp-thumb"
          >
            <img
              src={asset(portraitImages[11].src)}
              alt={portraitImages[11].alt}
              width={portraitImages[11].width}
              height={portraitImages[11].height}
              loading="lazy"
            />
          </a>
        </div>
        <div class="strip-masonry-item">
          <a
            href={asset(portraitImages[6].src)}
            data-pswp-width={portraitImages[6].width}
            data-pswp-height={portraitImages[6].height}
            data-pswp-id={portraitImages[6].src.split('/').pop()?.replace(/\.[^.]+$/, '').toLowerCase()}
            class="pswp-thumb"
          >
            <img
              src={asset(portraitImages[6].src)}
              alt={portraitImages[6].alt}
              width={portraitImages[6].width}
              height={portraitImages[6].height}
              loading="lazy"
            />
          </a>
        </div>
        <div class="strip-masonry-item">
          <a
            href={asset(portraitImages[3].src)}
            data-pswp-width={portraitImages[3].width}
            data-pswp-height={portraitImages[3].height}
            data-pswp-id={portraitImages[3].src.split('/').pop()?.replace(/\.[^.]+$/, '').toLowerCase()}
            class="pswp-thumb"
          >
            <img
              src={asset(portraitImages[3].src)}
              alt={portraitImages[3].alt}
              width={portraitImages[3].width}
              height={portraitImages[3].height}
              loading="lazy"
            />
          </a>
        </div>
      </div>
    </div>
  </section>


  {/* ══ SESSIONS ══════════════════════════════════════════════════════ */}
  <section class="section bg-soft">
    <div class="container">
      <span class="eyebrow">Sessions &amp; Pricing</span>
      <h2>Two sessions. Travel included.</h2>
      <p class="lead" style="margin-top: var(--space-4); max-width: 52ch;">
        Prices below include the Indianapolis travel fee. No surprises at booking.
      </p>

      <div class="grid-2" style="margin-top: var(--space-7);">

        <div class="pricing-card">
          <div>
            <h6>{pricing.essential.name}</h6>
            <div class="pricing-amount" style="margin-top: var(--space-4);">
              <span>$</span>{essentialPrice}
            </div>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              One hour, one location, five edited portraits. Good for professional images, personal
              brand work, milestones, or a gift.
            </p>
          </div>
          <ul class="pricing-features">
            <li>One hour at a single location</li>
            <li>5 professionally edited portraits</li>
            <li>High-resolution digital delivery</li>
            <li>All editing included</li>
            <li>Indianapolis travel included</li>
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/?session_type=essential&location=indianapolis')} class="btn btn-outline">
              Book the {pricing.essential.name.toLowerCase()}
            </a>
          </div>
        </div>

        <div class="pricing-card featured">
          <div>
            <h6>{pricing.extended.name}</h6>
            <div class="pricing-amount" style="margin-top: var(--space-4);">
              <span>$</span>{explorationPrice}
            </div>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              Three hours, one location, twenty edited portraits. More time means the session
              can find what it needs to — good for couples, families, or anything that
              needs to be worked out rather than executed.
            </p>
          </div>
          <ul class="pricing-features">
            <li>Three hours at a single location</li>
            <li>20 professionally edited portraits</li>
            <li>High-resolution digital delivery</li>
            <li>All editing included</li>
            <li>Indianapolis travel included</li>
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/?session_type=exploration&location=indianapolis')} class="btn btn-primary">
              Book the {pricing.extended.name.toLowerCase()}
            </a>
          </div>
        </div>

      </div>

      <p class="bespoke-note">
        Need something bigger — multiple locations, ongoing brand work, a larger selection?
        <a href={route('contact/?session_type=bespoke')}>Get in touch</a> and we'll figure out the right scope.
      </p>
    </div>
  </section>


  {/* ══ FAQ ═══════════════════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <span class="eyebrow">Questions</span>
      <h2>A few things people ask</h2>
      <div class="faq-list">
        <div class="faq-item">
          <p class="faq-q">{faqData[0].q}</p>
          <p class="faq-a">{faqData[0].a}</p>
        </div>
        <div class="faq-item">
          <p class="faq-q">{faqData[1].q}</p>
          <p class="faq-a">{faqData[1].a}</p>
        </div>
        <div class="faq-item">
          <p class="faq-q">{faqData[2].q}</p>
          <p class="faq-a">{faqData[2].a}</p>
        </div>
      </div>
    </div>
  </section>


  {/* ══ CTA ═══════════════════════════════════════════════════════════ */}
  <CTABand
    eyebrow="Available in Indianapolis"
    heading="Get in touch"
    body="Tell me what you're after — what the portraits are for, what you want them to do, what you're unsure about. We'll figure out the rest."
    primaryHref={route('contact/')}
    primaryLabel="Get in touch"
    secondaryHref={route('sessions/')}
    secondaryLabel="See sessions & pricing"
  />

</BaseLayout>

<style>
.pswp-thumb { display: block; }
</style>

<script type="module">
  import PhotoSwipeLightbox from 'https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe-lightbox.esm.min.js';

  const lightbox = new PhotoSwipeLightbox({
    gallery: document.body,
    children: 'a[data-pswp-width]',
    pswpModule: () => import('https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.esm.min.js'),
    history: false,
  });

  lightbox.on('afterInit', () => {
    const pswp = lightbox.pswp;
    const setHash = () => {
      const id = pswp.currSlide?.data.element?.dataset.pswpId;
      if (id) history.replaceState(null, '', `#${id}`);
    };
    pswp.on('change', setHash);
    setHash();
    pswp.on('destroy', () => {
      history.replaceState(null, '', location.pathname + location.search);
    });
  });

  lightbox.init();

  const hash = location.hash.slice(1);
  if (hash) {
    const links = Array.from(document.querySelectorAll('a[data-pswp-width]'));
    const index = links.findIndex(a => a.dataset.pswpId === hash);
    if (index !== -1) lightbox.loadAndOpen(index);
  }
</script>

