---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PackageCard from '../components/PackageCard.astro';

const base = import.meta.env.BASE_URL;
const root = base.endsWith('/') ? base : `${base}/`;
---

<BaseLayout
  title="Pricing | Zach Beauvais Photographer"
  description="Portrait session pricing for Zach Beauvais Photographer. Sessions in Lafayette, Indianapolis, and Chicago."
  path="/pricing/"
>
  <section class="section page-hero">
    <div class="container stack">
      <SectionHeading
        eyebrow="Pricing"
        title="Two sessions. Clear pricing. Everything edited and included."
        intro="Both packages include professional editing — no hidden retouching fees. Base pricing covers Lafayette, Indiana and within 30 miles of Urbana-Champaign, Illinois."
      />

      <div class="package-grid">
        <PackageCard
          name="Single-location session"
          price="$350"
          description="A focused portrait session at one location. Right for a social media refresh, a professional headshot, or a first collaborative session."
          items={['1 hour', '1 location', '5 professionally edited portraits', 'All editing included']}
        />
        <PackageCard
          name="Extended portrait session"
          price="$750"
          description="More time and room to explore — different lighting, looks, or locations within a single outing. Good for brands, personal projects, or deeper creative work."
          items={['3 hours', '1 location', '20 professionally edited photos', 'All editing included', 'More room for wardrobe, movement, and concept']}
        />
      </div>

      <div class="contact-grid">
        <article class="contact-card stack">
          <h3>Travel options</h3>
          <p>Base pricing covers Lafayette, Indiana and the Urbana-Champaign, Illinois area (within 30 miles).</p>
          <ul class="location-list" aria-label="Travel pricing">
            <li>Indianapolis — add $100 per session</li>
            <li>Chicago — add $200 per session</li>
          </ul>
        </article>
        <article class="contact-card stack">
          <h3>What's included</h3>
          <ul class="location-list" aria-label="What is included">
            <li>Professional-level editing on all delivered photos</li>
            <li>Pre-session conversation about vision and approach</li>
            <li>Guidance throughout the session</li>
            <li>Digital delivery of finished images</li>
          </ul>
        </article>
      </div>

      <div class="note-card stack">
        <h3>Questions before booking?</h3>
        <p class="measure">
          Not sure which session fits what you have in mind? Send a message — I'm happy to talk through the options
          before you commit to anything.
        </p>
        <div class="button-row">
          <a class="button button-primary" href={`${root}contact/`}>Get in touch</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
