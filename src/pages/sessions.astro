---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/sections/CTABand.astro';
import { route } from '../lib/paths';
import { pricing } from '../content/data';

// All prices and session details come from src/content/data.ts
// Edit there — changes reflect here and on the homepage automatically.
---

<BaseLayout
  title="Sessions &amp; Pricing"
  description={`Portrait sessions from $${pricing.essential.price}. ${pricing.essential.name} or ${pricing.extended.name}, with professional editing included.`}
>

  {/* ══ PAGE HEADER ══════════════════════════════════════════════════ */}
  <section class="page-header">
    <div class="container">
      <span class="eyebrow">Sessions &amp; Pricing</span>
      <h1>Two sessions, or something else entirely.</h1>
      <p class="lead" style="margin-top: var(--space-4); max-width: 52ch;">
        Two formats with editing included — good for most briefs. If yours is bigger
        or different, there's a third option: get in touch and we'll scope it together.
      </p>
    </div>
  </section>


  {/* ══ PRICING CARDS ════════════════════════════════════════════════
      Content (names, prices, features) comes from pricing in data.ts.
      To reorder: swap the two <div class="pricing-card"> blocks.
      To hide one: wrap it in {/* ... *\/}
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <div class="grid-2">
        <div class="pricing-card">
          <div>
            <h6>{pricing.essential.name}</h6>
            <div class="pricing-amount" style="margin-top: var(--space-4);">
              <span>$</span>{pricing.essential.price}
            </div>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              {pricing.essential.description}
            </p>
          </div>
          <ul class="pricing-features">
            {pricing.essential.features.map(f => <li>{f}</li>)}
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/?session=essential')} class="btn btn-outline">
              Book the {pricing.essential.name.toLowerCase()}
            </a>
          </div>
        </div>

        <div class="pricing-card featured">
          <div>
            <h6>{pricing.extended.name}</h6>
            <div class="pricing-amount" style="margin-top: var(--space-4);">
              <span>$</span>{pricing.extended.price}
            </div>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              {pricing.extended.description}
            </p>
          </div>
          <ul class="pricing-features">
            {pricing.extended.features.map(f => <li>{f}</li>)}
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/?session=extended')} class="btn btn-primary">
              Book the {pricing.extended.name.toLowerCase()}
            </a>
          </div>
        </div>
      </div>

      {/* ── Bespoke option ─────────────────────────────────────────── */}
      <div class="bespoke-card" style="margin-top: var(--space-7);">
        <div class="bespoke-inner">
          <div class="bespoke-text">
            <h6>Something more</h6>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3); max-width: 60ch;">
              Multiple locations, a larger selection of edited images, ongoing brand work,
              extended collaboration — if your brief is bigger or different, get in touch
              and we'll figure out the right scope together.
            </p>
            <div class="bespoke-tags" style="margin-top: var(--space-4);">
              <span>Multiple locations</span>
              <span>Extended editing</span>
              <span>Ongoing brand work</span>
              <span>Custom scope</span>
            </div>
          </div>
          <div class="bespoke-action">
            <p class="muted" style="font-size: var(--text-sm); margin-bottom: var(--space-4);">Scoped to your brief</p>
            <a href={route('contact/?session=bespoke')} class="btn btn-outline">
              Tell me what you need
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>


  {/* ══ TRAVEL ════════════════════════════════════════════════════════
      Travel fees come from pricing.travel in data.ts.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section-md bg-soft">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Travel</span>
        <h2>Available beyond Lafayette</h2>
        <p class="lead" style="margin-top: 1rem;">
          I work out of Lafayette and Urbana-Champaign, but I travel. Fees below cover
          the extra time and distance.
        </p>
      </div>
      <div class="grid-3" style="margin-top: var(--space-7);">
        <div class="card">
          <div class="card-body">
            <h5>Lafayette &amp; Urbana-Champaign</h5>
            <div class="travel-price">No additional fee</div>
            <p class="muted" style="font-size: var(--text-sm);">
              Sessions within 30 miles of Lafayette, Indiana or Urbana-Champaign, Illinois
              are included in the standard rate.
            </p>
          </div>
        </div>
        <div class="card">
          <div class="card-body">
            <h5>{pricing.travel.indianapolis.label}</h5>
            <div class="travel-price">+${pricing.travel.indianapolis.fee}</div>
            <p class="muted" style="font-size: var(--text-sm);">
              Either session, same approach.
            </p>
          </div>
        </div>
        <div class="card">
          <div class="card-body">
            <h5>{pricing.travel.chicago.label}</h5>
            <div class="travel-price">+${pricing.travel.chicago.fee}</div>
            <p class="muted" style="font-size: var(--text-sm);">
              Either session, same approach.
            </p>
          </div>
        </div>
      </div>
      <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-5);">
        Somewhere not listed? Get in touch.
      </p>
    </div>
  </section>


  {/* ══ WHAT'S INCLUDED ═══════════════════════════════════════════════
      Six items in two columns. Edit headings and body text below.
      To add an item: copy one <div class="included-item"> block.
      To hide a column: wrap the outer <div class="stack-lg"> in {/* ... *\/}
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What to expect</span>
        <h2>What you're actually getting</h2>
      </div>
      <div class="grid-2" style="margin-top: var(--space-7); align-items: start; gap: var(--space-10);">
        <div class="stack-lg">
          <div class="included-item">
            <h5>A pre-session conversation</h5>
            <p class="muted" style="font-size: var(--text-sm);">
              Before we shoot, we talk. What are you looking for? What setting feels right?
              What do you want these portraits to do for you? That conversation shapes everything.
            </p>
          </div>
          <div class="included-item">
            <h5>Professional editing</h5>
            <p class="muted" style="font-size: var(--text-sm);">
              Every delivered image is colour-graded, retouched, and ready to use —
              editing is included in the price.
            </p>
          </div>
          <div class="included-item">
            <h5>Digital delivery</h5>
            <p class="muted" style="font-size: var(--text-sm);">
              Your final images are delivered via a private online gallery, available
              to download at any time.
            </p>
          </div>
        </div>
        <div class="stack-lg">
          <div class="included-item">
            <h5>Single-location focus</h5>
            <p class="muted" style="font-size: var(--text-sm);">
              Sessions are at one location — this isn't a limitation, it's a choice.
              Staying in one place lets us go deeper, settle in, and find the images that
              live there rather than rushing between spots.
            </p>
          </div>
          <div class="included-item">
            <h5>For people &amp; brands</h5>
            <p class="muted" style="font-size: var(--text-sm);">
              Personal portraits or brand work — the format doesn't change much. You still
              need images that look like the real thing, not a stock-photo version of it.
            </p>
          </div>
          <div class="included-item">
            <h5>Usage rights</h5>
            <p class="muted" style="font-size: var(--text-sm);">
              All delivered images are yours — personal use, commercial use, print, web,
              whatever you need.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>


  {/* ══ FAQ ═══════════════════════════════════════════════════════════
      Click to expand/collapse. Edit questions and answers below.
      To add a question: copy a <details class="faq-item"> block.
      To remove a question: delete its <details> block.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section bg-soft">
    <div class="container container-narrow">
      <div class="section-header">
        <span class="eyebrow">Questions</span>
        <h2>Common questions</h2>
      </div>
      <div class="faq-list" style="margin-top: var(--space-7);">
        <details class="faq-item">
          <summary>Do I need to have photography experience?</summary>
          <p>
            Not at all. Most people feel a little awkward in front of a camera — that's completely
            normal, and part of my job is helping you get past it. We'll take our time, and by the
            end of the session you'll have forgotten the camera is there.
          </p>
        </details>
        <details class="faq-item">
          <summary>How do I choose a location?</summary>
          <p>
            We figure this out together in our pre-session conversation. It might be somewhere
            meaningful to you, somewhere that reflects your aesthetic, or simply a well-lit space
            that suits the mood you're going for. I'll make suggestions if you'd like them.
          </p>
        </details>
        <details class="faq-item">
          <summary>How long does editing take?</summary>
          <p>
            Typically 1–2 weeks after the session. You'll receive a link to a private
            online gallery when your images are ready.
          </p>
        </details>
        <details class="faq-item">
          <summary>Can I book for a special event or celebration?</summary>
          <p>
            Yes. I'm happy to work around events — engagements, birthdays, graduations.
            Mention it when you get in touch and we'll plan from there.
          </p>
        </details>
        <details class="faq-item">
          <summary>What if the weather doesn't cooperate for an outdoor session?</summary>
          <p>
            We'll reschedule at no additional cost. Weather happens — I'd rather get the
            session right than push through conditions that don't serve the work.
          </p>
        </details>
        <details class="faq-item">
          <summary>Can I book for my small business or brand?</summary>
          <p>
            Yes. I work with small businesses on brand imagery — the kind that looks like you
            made it, not like you bought it from a template site. Tell me what you're building
            and we'll figure out the right approach.
          </p>
        </details>
        <details class="faq-item">
          <summary>What if neither session is quite what I need?</summary>
          <p>
            Get in touch and describe what you're after. The two formats work well for most
            things, but not everything — if you need multiple locations, a bigger edit, ongoing
            work, or something I haven't listed, I'd rather figure out the right scope in
            conversation than have you pick a box that doesn't fit.
          </p>
        </details>
      </div>
    </div>
  </section>


  {/* ══ CTA ═══════════════════════════════════════════════════════════ */}
  <CTABand
    eyebrow="Book a session"
    heading="Not sure which session?"
    body="Get in touch and we'll figure out what fits."
    primaryHref={route('contact/')}
    primaryLabel="Get in touch"
  />

</BaseLayout>

<style>
  .travel-price {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    font-weight: 300;
    color: var(--color-primary);
    margin-block: var(--space-3);
  }
  .included-item h5 { margin-bottom: var(--space-2); }

  .bespoke-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg, var(--radius));
    padding: var(--space-8);
  }
  .bespoke-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
    align-items: flex-start;
    justify-content: space-between;
  }
  .bespoke-text { flex: 1 1 40ch; }
  .bespoke-action {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .bespoke-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .bespoke-tags span {
    font-size: var(--text-xs, var(--text-sm));
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: var(--space-1) var(--space-3);
  }

  .faq-list { display: flex; flex-direction: column; border-top: 1px solid var(--color-border); }
  .faq-item { border-bottom: 1px solid var(--color-border); }
  .faq-item summary {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-primary);
    padding: var(--space-5) 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: "+";
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: 300;
    color: var(--color-accent);
    flex-shrink: 0;
    transition: transform var(--transition);
  }
  .faq-item[open] summary::after { transform: rotate(45deg); }
  .faq-item p { padding-bottom: var(--space-5); color: var(--color-muted); font-size: var(--text-sm); }
</style>
