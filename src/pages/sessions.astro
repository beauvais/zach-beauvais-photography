---
import BaseLayout from '../layouts/BaseLayout.astro';
import { route } from '../lib/paths';
---

<BaseLayout
  title="Sessions &amp; Pricing"
  description="Portrait sessions from $350. One-hour essential session or three-hour extended session, with professional editing included. Lafayette, Indianapolis, Chicago."
>
  <section class="page-header">
    <div class="container">
      <span class="eyebrow">Sessions &amp; Pricing</span>
      <h1>Simple, all-inclusive pricing</h1>
      <p class="lead" style="margin-top: var(--space-4); max-width: 52ch;">
        Two formats, both with professional editing included. No surprises.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <div class="pricing-card">
          <div>
            <h6>Essential Session</h6>
            <div class="pricing-amount" style="margin-top: var(--space-4);">
              <span>$</span>350
            </div>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              A focused, one-hour session ideal for individuals, professional headshots,
              personal brands, or portrait gifts.
            </p>
          </div>
          <ul class="pricing-features">
            <li>One hour at a single location</li>
            <li>5 professionally edited portraits</li>
            <li>High-resolution digital delivery</li>
            <li>All editing included — no additional fees</li>
            <li>Within 30 miles of Lafayette, IN or Urbana-Champaign, IL</li>
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/?session=essential')} class="btn btn-outline">Book the essential session</a>
          </div>
        </div>

        <div class="pricing-card featured">
          <div>
            <h6>Extended Session</h6>
            <div class="pricing-amount" style="margin-top: var(--space-4);">
              <span>$</span>750
            </div>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              Three hours gives us time to explore, relax, and find the images that really
              work — ideal for couples, families, creatives, and businesses.
            </p>
          </div>
          <ul class="pricing-features">
            <li>Three hours at a single location</li>
            <li>20 professionally edited portraits</li>
            <li>High-resolution digital delivery</li>
            <li>All editing included — no additional fees</li>
            <li>Within 30 miles of Lafayette, IN or Urbana-Champaign, IL</li>
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/?session=extended')} class="btn btn-primary">Book the extended session</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-md bg-soft">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Travel</span>
        <h2>Available beyond Lafayette</h2>
        <p class="lead" style="margin-top: 1rem;">
          I'm happy to travel. Additional fees below are per session, added to whichever
          session format you book.
        </p>
      </div>

      <div class="grid-3" style="margin-top: var(--space-7);">
        <div class="card">
          <div class="card-body">
            <h5>Lafayette &amp; Urbana-Champaign</h5>
            <div class="travel-price">No additional fee</div>
            <p class="muted" style="font-size: var(--text-sm);">
              Sessions within 30 miles of Lafayette, Indiana or Urbana-Champaign, Illinois
              are included in the standard rate.
            </p>
          </div>
        </div>
        <div class="card">
          <div class="card-body">
            <h5>Indianapolis</h5>
            <div class="travel-price">+$100</div>
            <p class="muted" style="font-size: var(--text-sm);">
              All session types available in Indianapolis. Travel fee added to session cost.
            </p>
          </div>
        </div>
        <div class="card">
          <div class="card-body">
            <h5>Chicago</h5>
            <div class="travel-price">+$200</div>
            <p class="muted" style="font-size: var(--text-sm);">
              All session types available in Chicago. Travel fee added to session cost.
            </p>
          </div>
        </div>
      </div>

      <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-5);">
        Interested in a location not listed here? Get in touch — I'm open to other arrangements.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What to expect</span>
        <h2>Everything you need, nothing you don't</h2>
      </div>

      <div class="grid-2" style="margin-top: var(--space-7); align-items: start; gap: var(--space-10);">
        <div class="stack-lg">
          <div class="included-item">
            <h5>A pre-session conversation</h5>
            <p class="muted" style="font-size: var(--text-sm);">
              Before we shoot, we talk. What are you looking for? What setting feels right?
              What do you want these portraits to do for you? That conversation shapes everything.
            </p>
          </div>
          <div class="included-item">
            <h5>Professional editing</h5>
            <p class="muted" style="font-size: var(--text-sm);">
              Every delivered image is colour-graded, retouched, and ready to use.
              Editing is included in all session prices — you'll never receive a raw file
              and be left to figure out the rest.
            </p>
          </div>
          <div class="included-item">
            <h5>High-resolution digital delivery</h5>
            <p class="muted" style="font-size: var(--text-sm);">
              Your final images are delivered as high-resolution JPEGs via a private
              online gallery, available to download at any time.
            </p>
          </div>
        </div>

        <div class="stack-lg">
          <div class="included-item">
            <h5>Single-location focus</h5>
            <p class="muted" style="font-size: var(--text-sm);">
              Sessions are at one location — this isn't a limitation, it's a choice.
              Staying in one place lets us go deeper, settle in, and find the images that
              live there rather than rushing between spots.
            </p>
          </div>
          <div class="included-item">
            <h5>For people &amp; brands</h5>
            <p class="muted" style="font-size: var(--text-sm);">
              My sessions work equally well for personal portraits and professional brand
              imagery. If you're building a brand identity or just want photography
              that represents you honestly, this is the format.
            </p>
          </div>
          <div class="included-item">
            <h5>Usage rights</h5>
            <p class="muted" style="font-size: var(--text-sm);">
              You receive full personal and commercial usage rights for all delivered images.
              Use them for social media, print, your website, or anything else you need.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-soft">
    <div class="container container-narrow">
      <div class="section-header">
        <span class="eyebrow">Questions</span>
        <h2>Common questions</h2>
      </div>

      <div class="faq-list" style="margin-top: var(--space-7);">
        <details class="faq-item">
          <summary>Do I need to have photography experience?</summary>
          <p>
            Not at all. Most people feel a little awkward in front of a camera — that's completely
            normal, and part of my job is helping you get past it. We'll take our time, and by the
            end of the session you'll have forgotten the camera is there.
          </p>
        </details>
        <details class="faq-item">
          <summary>How do I choose a location?</summary>
          <p>
            We figure this out together in our pre-session conversation. It might be somewhere
            meaningful to you, somewhere that reflects your aesthetic, or simply a well-lit space
            that suits the mood you're going for. I'll make suggestions if you'd like them.
          </p>
        </details>
        <details class="faq-item">
          <summary>How long does editing take?</summary>
          <p>
            Typically 1–2 weeks after the session. You'll receive a link to a private
            online gallery when your images are ready.
          </p>
        </details>
        <details class="faq-item">
          <summary>Can I book for a special event or celebration?</summary>
          <p>
            Yes — portrait sessions make wonderful gifts, and I'm happy to work around events
            like engagements, birthdays, graduations, and other occasions. Mention this when
            you reach out and we'll plan accordingly.
          </p>
        </details>
        <details class="faq-item">
          <summary>What if the weather doesn't cooperate for an outdoor session?</summary>
          <p>
            We'll reschedule at no additional cost. Weather happens — I'd rather get the
            session right than push through conditions that don't serve the work.
          </p>
        </details>
        <details class="faq-item">
          <summary>Can I book for my small business or brand?</summary>
          <p>
            Absolutely. I work with small businesses to create brand imagery that's visually
            distinctive and tells a genuine story. Get in touch with a brief description of
            what you're looking for and we'll discuss the right approach.
          </p>
        </details>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container-narrow">
      <span class="eyebrow">Book a session</span>
      <h2>Ready to get started?</h2>
      <p>Send a message and let's work out the details together.</p>
      <a href={route('contact/')} class="btn btn-accent btn-lg">Get in touch</a>
    </div>
  </section>
</BaseLayout>

<style>
  .travel-price {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    font-weight: 300;
    color: var(--color-primary);
    margin-block: var(--space-3);
  }

  .included-item h5 { margin-bottom: var(--space-2); }

  .faq-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border);
  }

  .faq-item { border-bottom: 1px solid var(--color-border); }

  .faq-item summary {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-primary);
    padding: var(--space-5) 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary::after {
    content: "+";
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: 300;
    color: var(--color-accent);
    flex-shrink: 0;
    transition: transform var(--transition);
  }

  .faq-item[open] summary::after { transform: rotate(45deg); }

  .faq-item p {
    padding-bottom: var(--space-5);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }
</style>
