---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/sections/CTABand.astro';
import { asset, route } from '../lib/paths';
import { pricing, portraitImages, landscapeImages } from '../content/data';

const essentialPrice = pricing.essential.price + pricing.travel.chicago.fee;
const explorationPrice = pricing.extended.price + pricing.travel.chicago.fee;

const faqData = [
  {
    q: "Is the travel fee already included in the Chicago prices?",
    a: "Yes. The Chicago travel fee is already built into the prices shown on this page. No extra charges at booking."
  },
  {
    q: "Where do Chicago sessions take place?",
    a: "Anywhere in the city that fits the brief — Wicker Park, Logan Square, the lakefront, South Side neighbourhoods. Chicago has a lot of good locations. We work it out together based on what the portrait needs."
  },
  {
    q: "How much lead time do I need to book a Chicago session?",
    a: "A couple of weeks is usually enough, but Chicago sessions need a bit more planning than local ones since I'm travelling from Lafayette. Getting logistics sorted early means we can be more deliberate about the location."
  }
];

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Zach Beauvais Photography",
  "description": "Portrait photography in Chicago, Illinois. Collaborative sessions for individuals, families, and small businesses. Travel from Lafayette included in price.",
  "url": "https://zachbeauvais.com/chicago/",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Chicago",
    "addressRegion": "IL",
    "addressCountry": "US"
  },
  "areaServed": ["Chicago", "Chicagoland", "Illinois"],
  "priceRange": `$${essentialPrice}–$${explorationPrice}`
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a }
  }))
};

const schema = JSON.stringify([localBusiness, faqSchema]);
---

<BaseLayout
  title="Portrait Photographer in Chicago, Illinois"
  description={`Portrait photography in Chicago — $${essentialPrice} and up, travel included. Collaborative sessions for individuals, families, and small businesses. Based in the Midwest, working in Chicago.`}
  schema={schema}
>

  {/* ══ PAGE HEADER ══════════════════════════════════════════════════ */}
  <section class="page-header">
    <div class="container">
      <span class="eyebrow">Portrait photographer</span>
      <h1>Chicago, Illinois.</h1>
      <p class="lead" style="margin-top: var(--space-4); max-width: 52ch;">
        Portrait sessions in Chicago, with travel from Lafayette included in the price.
        Chicago has no shortage of photographers. Here's what makes this one different.
      </p>
    </div>
  </section>


  {/* ══ THE APPROACH ══════════════════════════════════════════════════
      Split: text left, portrait right.
      [18] dancer-dark-main — dramatic, dark bg — fits Chicago's scale and energy.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section bg-strong">
    <div class="container">
      <div class="approach-split">
        <div class="stack">
          <p>
            I'm based in Lafayette, Indiana — about three hours south. I don't live in Chicago,
            I visit it deliberately, with a specific brief and a camera. That distance isn't a
            disadvantage. It means I don't have a default route or a favourite easy location.
            Every Chicago session starts from scratch.
          </p>
          <p>
            What doesn't change: we talk before we start. We figure out what the portrait is for
            and who it's of. We find the location that fits that. Then we work.
          </p>
        </div>
        <div class="approach-image">
          <img
            src={asset(portraitImages[18].src)}
            alt={portraitImages[18].alt}
            width={portraitImages[18].width}
            height={portraitImages[18].height}
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>


  {/* ══ WHO THIS IS FOR ═══════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <span class="eyebrow">Good for</span>
      <h2>Chicago individuals, families, and small businesses</h2>
      <div class="who-grid">
        <p>
          Chicago has more photographers per square mile than anywhere else I work. If you've
          found your way here, you're probably looking for something specific — a particular
          approach, a particular kind of portrait, something you haven't found closer to home.
        </p>
        <p>
          I work with individuals building a personal or professional brand, families who want
          portraits that feel true rather than tidy, and small businesses that need imagery
          with some character to it.
        </p>
        <p>
          The same work I do everywhere, in a city that gives it more room.
        </p>
      </div>
    </div>
  </section>


  {/* ══ PHOTO STRIP ═══════════════════════════════════════════════════
      [0]  woman-closeup     — B&W, direct gaze, strong
      [10] two-people-studio — studio, together
      landscapeImages[0]     — abstract-1, form and tone (signals the eye behind the portraits)
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section-sm bg-strong">
    <div class="container">
      <div class="strip-masonry">
        <div class="strip-masonry-item">
          <img
            src={asset(portraitImages[0].src)}
            alt={portraitImages[0].alt}
            width={portraitImages[0].width}
            height={portraitImages[0].height}
            loading="lazy"
          />
        </div>
        <div class="strip-masonry-item">
          <img
            src={asset(portraitImages[10].src)}
            alt={portraitImages[10].alt}
            width={portraitImages[10].width}
            height={portraitImages[10].height}
            loading="lazy"
          />
        </div>
        <div class="strip-masonry-item">
          <img
            src={asset(landscapeImages[0].src)}
            alt={landscapeImages[0].alt}
            width={landscapeImages[0].width}
            height={landscapeImages[0].height}
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>


  {/* ══ SESSIONS ══════════════════════════════════════════════════════ */}
  <section class="section bg-soft">
    <div class="container">
      <span class="eyebrow">Sessions &amp; Pricing</span>
      <h2>Two sessions. Travel included.</h2>
      <p class="lead" style="margin-top: var(--space-4); max-width: 52ch;">
        Prices below include the Chicago travel fee. No surprises at booking.
      </p>

      <div class="grid-2" style="margin-top: var(--space-7);">

        <div class="pricing-card">
          <div>
            <h6>{pricing.essential.name}</h6>
            <div class="pricing-amount" style="margin-top: var(--space-4);">
              <span>$</span>{essentialPrice}
            </div>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              One hour, one location, five edited portraits. Good for professional images, personal
              brand work, milestones, or a gift.
            </p>
          </div>
          <ul class="pricing-features">
            <li>One hour at a single location</li>
            <li>5 professionally edited portraits</li>
            <li>High-resolution digital delivery</li>
            <li>All editing included</li>
            <li>Chicago travel included</li>
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/?session_type=essential&location=chicago')} class="btn btn-outline">
              Book the {pricing.essential.name.toLowerCase()}
            </a>
          </div>
        </div>

        <div class="pricing-card featured">
          <div>
            <h6>{pricing.extended.name}</h6>
            <div class="pricing-amount" style="margin-top: var(--space-4);">
              <span>$</span>{explorationPrice}
            </div>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              Three hours, one location, twenty edited portraits. More time means the session
              can find what it needs to — good for couples, families, or anything that
              needs to be worked out rather than executed.
            </p>
          </div>
          <ul class="pricing-features">
            <li>Three hours at a single location</li>
            <li>20 professionally edited portraits</li>
            <li>High-resolution digital delivery</li>
            <li>All editing included</li>
            <li>Chicago travel included</li>
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/?session_type=exploration&location=chicago')} class="btn btn-primary">
              Book the {pricing.extended.name.toLowerCase()}
            </a>
          </div>
        </div>

      </div>

      <p class="bespoke-note">
        Need something bigger — multiple locations, ongoing brand work, a larger selection?
        <a href={route('contact/?session_type=bespoke')}>Get in touch</a> and we'll figure out the right scope.
      </p>
    </div>
  </section>


  {/* ══ FAQ ═══════════════════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <span class="eyebrow">Questions</span>
      <h2>A few things people ask</h2>
      <div class="faq-list">
        <div class="faq-item">
          <p class="faq-q">{faqData[0].q}</p>
          <p class="faq-a">{faqData[0].a}</p>
        </div>
        <div class="faq-item">
          <p class="faq-q">{faqData[1].q}</p>
          <p class="faq-a">{faqData[1].a}</p>
        </div>
        <div class="faq-item">
          <p class="faq-q">{faqData[2].q}</p>
          <p class="faq-a">{faqData[2].a}</p>
        </div>
      </div>
    </div>
  </section>


  {/* ══ CTA ═══════════════════════════════════════════════════════════ */}
  <CTABand
    eyebrow="Available in Chicago"
    heading="Get in touch"
    body="Tell me what you're after — what the portraits are for, what you want them to do, what you're unsure about. We'll figure out the rest."
    primaryHref={route('contact/')}
    primaryLabel="Get in touch"
    secondaryHref={route('sessions/')}
    secondaryLabel="See sessions & pricing"
  />

</BaseLayout>

