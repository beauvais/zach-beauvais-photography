---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { parsePostId, coverImageUrl, sortByDate, formatDate, taxonomySlug, taxonomyLabel } from '../../../lib/blog';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  // Collect all unique categories
  const categorySet = new Set<string>();
  for (const post of allPosts) {
    for (const cat of post.data.categories) {
      categorySet.add(taxonomySlug(cat));
    }
  }

  return Array.from(categorySet).map(catSlug => {
    const posts = sortByDate(
      allPosts.filter(p => p.data.categories.some(c => taxonomySlug(c) === catSlug))
    );
    return {
      params: { category: catSlug },
      props: { posts, catSlug },
    };
  });
}

const { posts, catSlug } = Astro.props;
const label = taxonomyLabel(catSlug);

function textureIndex(id: string): number {
  let h = 0;
  for (const c of id) h = (h * 31 + c.charCodeAt(0)) | 0;
  return ((h % 7) + 7) % 7;
}
function textureFallback(id: string): string {
  return `/blog/textures/texture-${textureIndex(id) + 1}.svg`;
}

// All categories for sidebar
const allPosts = await getCollection('blog');
const categoryCount: Record<string, number> = {};
for (const post of allPosts) {
  for (const cat of post.data.categories) {
    const s = taxonomySlug(cat);
    categoryCount[s] = (categoryCount[s] ?? 0) + 1;
  }
}
const allCategories = Object.entries(categoryCount).sort((a, b) => b[1] - a[1]).slice(0, 20);
---

<BaseLayout
  title={`${label} — Writing`}
  description={`Posts about ${label} by Zach Beauvais.`}
>
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Site navigation">
        <a href="/">Home</a>
        <span class="breadcrumb-sep" aria-hidden="true">→</span>
        <a href="/blog">Writing</a>
        <span class="breadcrumb-sep" aria-hidden="true">→</span>
        <span>Category</span>
      </nav>
      <span class="eyebrow">Category</span>
      <h1>{label}.</h1>
      <p class="lead">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
    </div>
  </div>

  <div class="section">
    <div class="container">
      <div class="blog-layout">
        <main class="blog-main">
          <div class="blog-post-list">
            {posts.map(post => {
              const { year, slug } = parsePostId(post);
              const imgSrc = coverImageUrl(post) ?? textureFallback(post.id);
              return (
                <article class="blog-card">
                  <a href={`/blog/${year}/${slug}`} class="blog-card-image-wrap" aria-hidden="true" tabindex="-1">
                    <img src={imgSrc} alt="" class="blog-card-image" loading="lazy" />
                  </a>
                  <div class="blog-card-body">
                    <div class="blog-card-meta">
                      <time datetime={post.data.date.toISOString().slice(0, 10)} class="blog-card-date">
                        {formatDate(post.data.date)}
                      </time>
                      <span class="blog-card-cats">
                        {post.data.categories.map((cat, i) => (
                          <span>
                            <a href={`/blog/category/${taxonomySlug(cat)}`} class="blog-tag">
                              {taxonomyLabel(cat)}
                            </a>
                            {i < post.data.categories.length - 1 && ' '}
                          </span>
                        ))}
                      </span>
                    </div>
                    <h3 class="blog-card-title">
                      <a href={`/blog/${year}/${slug}`}>{post.data.title}</a>
                    </h3>
                  </div>
                </article>
              );
            })}
          </div>
        </main>

        <aside class="blog-sidebar">
          <div class="blog-sidebar-block">
            <h6>All categories</h6>
            <ul class="blog-sidebar-list">
              {allCategories.map(([s, count]) => (
                <li>
                  <a
                    href={`/blog/category/${s}`}
                    class={`blog-sidebar-link ${s === catSlug ? 'is-active' : ''}`}
                  >
                    {taxonomyLabel(s)}
                    <span class="blog-sidebar-count">{count}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="blog-sidebar-block">
            <a href="/blog" class="btn btn-outline btn-sm">← All writing</a>
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>
