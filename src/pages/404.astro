---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" noindex={true}>
  <section class="section" style="min-height: 60vh; display: flex; align-items: center;">
    <div class="container">
      <div style="max-width: 40rem;">
        <span class="eyebrow">404</span>
        <h1>Page not found</h1>
        <p class="lead" style="margin-top: var(--space-4);">
          This page doesn't seem to exist. Let's get you back on track.
        </p>
        <div class="btn-row" style="margin-top: var(--space-7);">
          <a href="/" class="btn btn-primary">Go home</a>
          <a href="/portfolio/" class="btn btn-outline">View portfolio</a>
          <a href="/contact/" class="btn btn-ghost">Get in touch</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
