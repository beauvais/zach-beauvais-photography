---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABand from '../../components/sections/CTABand.astro';
import { asset, route } from '../../lib/paths';
import { allImages } from '../../content/data';

// allImages is portraits + landscape combined, defined in data.ts
---

<BaseLayout
  title="Portfolio"
  description="The complete portfolio of Zach Beauvais — collaborative portraits, landscape, and abstract photography from Lafayette, Indiana."
>

  {/* ══ PAGE HEADER ══════════════════════════════════════════════════ */}
  <section class="page-header">
    <div class="container">
      <span class="eyebrow">Portfolio</span>
      <h1>All work</h1>
      <p class="lead" style="margin-top: var(--space-4); max-width: 48ch;">
        Portraits, landscape, and abstract — everything in one place.
      </p>
      <div class="portfolio-nav" style="margin-top: var(--space-6);">
        <a href={route('portfolio/')}           class="btn btn-primary btn-sm">All</a>
        <a href={route('portfolio/portraits/')} class="btn btn-outline btn-sm">Portraits</a>
        <a href={route('portfolio/landscape/')} class="btn btn-outline btn-sm">Landscape &amp; Art</a>
      </div>
    </div>
  </section>


  {/* ══ GALLERY ═══════════════════════════════════════════════════════
      All images from allImages (data.ts). Click to open lightbox.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section-md">
    <div class="gallery-container">
      <div class="gallery-grid" id="gallery">
        {allImages.map((img, i) => (
          <button
            class="gallery-item"
            data-index={i}
            data-src={asset(img.src)}
            data-alt={img.alt}
            aria-label={`View larger: ${img.alt}`}
          >
            <img src={asset(img.src)} alt={img.alt} width={img.width} height={img.height} loading="lazy" />
            <div class="gallery-item-overlay">
              <span class="gallery-item-label">{img.alt}</span>
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>


  {/* ══ LIGHTBOX (no edits needed) ════════════════════════════════════ */}
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <button class="lightbox-close" id="lb-close" aria-label="Close photo viewer">✕</button>
    <button class="lightbox-nav lightbox-prev" id="lb-prev" aria-label="Previous photo">‹</button>
    <div class="lightbox-inner">
      <img class="lightbox-img" id="lb-img" src="" alt="" />
    </div>
    <button class="lightbox-nav lightbox-next" id="lb-next" aria-label="Next photo">›</button>
    <div class="lightbox-counter" id="lb-counter"></div>
  </div>


  {/* ══ CTA ═══════════════════════════════════════════════════════════ */}
  <CTABand
    eyebrow="Work together"
    heading="Like what you see?"
    body="Sessions from $350. Let's discuss your portrait."
    primaryHref={route('contact/')}
    primaryLabel="Book a session"
    secondaryHref={route('sessions/')}
    secondaryLabel="See pricing"
  />

</BaseLayout>

<style>
  .gallery-container { padding-inline: 2px; }
  .portfolio-nav { display: flex; flex-wrap: wrap; gap: var(--space-2); }
</style>

<script>
  const items = document.querySelectorAll<HTMLButtonElement>('.gallery-item');
  const lightbox = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbClose = document.getElementById('lb-close')!;
  const lbPrev = document.getElementById('lb-prev')!;
  const lbNext = document.getElementById('lb-next')!;
  const lbCounter = document.getElementById('lb-counter')!;

  let current = 0;
  const images = Array.from(items).map(el => ({ src: el.dataset.src!, alt: el.dataset.alt! }));

  function open(i: number) { current = i; show(); lightbox.classList.add('is-open'); document.body.style.overflow = 'hidden'; lbClose.focus(); }
  function close() { lightbox.classList.remove('is-open'); document.body.style.overflow = ''; }
  function show() { lbImg.src = images[current].src; lbImg.alt = images[current].alt; lbCounter.textContent = `${current + 1} / ${images.length}`; }
  function prev() { current = (current - 1 + images.length) % images.length; show(); }
  function next() { current = (current + 1) % images.length; show(); }

  items.forEach((btn, i) => btn.addEventListener('click', () => open(i)));
  lbClose.addEventListener('click', close);
  lbPrev.addEventListener('click', prev);
  lbNext.addEventListener('click', next);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) close(); });
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('is-open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') prev();
    if (e.key === 'ArrowRight') next();
  });
</script>
