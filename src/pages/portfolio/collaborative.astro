---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LightboxGallery from '../../components/LightboxGallery.astro';
import { getCollection } from 'astro:content';

const allItems = await getCollection('portfolio');
const items = allItems
  .filter((item) => item.data.category === 'collaborative')
  .sort((a, b) => a.data.order - b.data.order);

const imageModules = import.meta.glob('../../assets/portfolio/collaborative/*.{jpg,jpeg,png,webp}', {
  eager: true,
});

const galleryItems = items
  .map((item) => {
    const key = `../../assets/portfolio/collaborative/${item.data.coverImage}`;
    const mod = imageModules[key] as { default?: { src?: string; width?: number; height?: number } };

    if (!mod?.default?.src) return null;

    return {
      src: mod.default.src,
      alt: item.data.coverAlt,
      width: mod.default.width,
      height: mod.default.height,
    };
  })
  .filter(Boolean);
---

<BaseLayout
  title="Collaborative Portraits"
  description="Collaborative portrait photography shaped by expression, atmosphere, and visual storytelling."
>
  <section class="page-intro container">
    <p class="eyebrow">Portfolio</p>
    <h1>Collaborative Portraits</h1>
    <p class="lede">
      Portraits shaped through collaboration, feeling, gesture, and visual storytelling.
    </p>
  </section>

  <section class="container portfolio-copy-grid">
    <div>
      <p>
        These portraits are made with people, not of them. The aim is not simply to document,
        but to create space for expression, presence, and a sense of shared authorship.
      </p>
    </div>
    <div>
      <p>
        Click any image to view it larger.
      </p>
    </div>
  </section>

  <section class="container">
    <LightboxGallery items={galleryItems} galleryId="collaborative-gallery" />
  </section>
</BaseLayout>