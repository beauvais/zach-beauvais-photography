---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LightboxGallery from '../../components/LightboxGallery.astro';
import { getCollection } from 'astro:content';

const allItems = await getCollection('portfolio');
const items = allItems
  .filter((item) => item.data.category === 'landscape')
  .sort((a, b) => a.data.order - b.data.order);

const imageModules = import.meta.glob('../../assets/portfolio/landscape/*.{jpg,jpeg,png,webp}', {
  eager: true,
});

const galleryItems = items
  .map((item) => {
    const key = `../../assets/portfolio/landscape/${item.data.coverImage}`;
    const mod = imageModules[key] as { default?: { src?: string; width?: number; height?: number } };

    if (!mod?.default?.src) return null;

    return {
      src: mod.default.src,
      alt: item.data.coverAlt,
      width: mod.default.width,
      height: mod.default.height,
    };
  })
  .filter(Boolean);
---

<BaseLayout
  title="Landscape & Abstract"
  description="Landscape and abstract photography rooted in texture, atmosphere, and observation."
>
  <section class="page-intro container">
    <p class="eyebrow">Portfolio</p>
    <h1>Landscape &amp; Abstract</h1>
    <p class="lede">
      Landscape and abstract work rooted in observation, structure, texture, and atmosphere.
    </p>
  </section>

  <section class="container portfolio-copy-grid">
    <div>
      <p>
        This work grows out of attention to weather, surface, distance, and the way a place can
        become image, pattern, or abstraction.
      </p>
    </div>
    <div>
      <p>
        Click any image to view it larger.
      </p>
    </div>
  </section>

  <section class="container">
    <LightboxGallery items={galleryItems} galleryId="landscape-gallery" />
  </section>
</BaseLayout>