---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABand from '../../components/sections/CTABand.astro';
import { asset, route } from '../../lib/paths';
import { landscapeImages, portraitImages } from '../../content/data';

// To add a landscape/art image: add it to landscapeImages in src/content/data.ts
---

<BaseLayout
  title="Landscape &amp; Art"
  description="Landscape and abstract photography by Zach Beauvais — the observational eye that informs the portrait work. Lafayette, Indiana."
  ogImage={`/${landscapeImages[0].src}`}
>

  {/* ══ PAGE HEADER ══════════════════════════════════════════════════ */}
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumb">
        <a href={route('portfolio/')}>Portfolio</a>
        <span class="breadcrumb-sep">/</span>
        <span>Landscape &amp; Art</span>
      </nav>
      <h1>Landscape &amp; Art</h1>
      <p class="lead" style="margin-top: var(--space-4); max-width: 52ch;">
        The observational eye that informs the portrait work — texture, light, and the
        abstract world.
      </p>
      <div class="portfolio-nav" style="margin-top: var(--space-6);">
        <a href={route('portfolio/')}           class="btn btn-outline btn-sm">All work</a>
        <a href={route('portfolio/portraits/')} class="btn btn-outline btn-sm">Portraits</a>
        <a href={route('portfolio/landscape/')} class="btn btn-primary btn-sm">Landscape &amp; Art</a>
      </div>
    </div>
  </section>


  {/* ══ HERO IMAGE GRID ═══════════════════════════════════════════════
      First 3 landscape images in a feature layout.
      Edit landscapeImages order in data.ts to change which appear here.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section-sm">
    <div class="container">
      <div class="landscape-hero">
        <div class="landscape-hero-wide">
          <img src={asset(landscapeImages[0].src)} alt={landscapeImages[0].alt} width={landscapeImages[0].width} height={landscapeImages[0].height} loading="lazy" />
        </div>
        <div class="landscape-hero-pair">
          <div class="lh-pair-item"><img src={asset(landscapeImages[2].src)} alt={landscapeImages[2].alt} width={landscapeImages[2].width} height={landscapeImages[2].height} loading="lazy" /></div>
          <div class="lh-pair-item"><img src={asset(landscapeImages[5].src)} alt={landscapeImages[5].alt} width={landscapeImages[5].width} height={landscapeImages[5].height} loading="lazy" /></div>
        </div>
      </div>
    </div>
  </section>


  {/* ══ GALLERY ═══════════════════════════════════════════════════════
      All images from landscapeImages (data.ts). Click to open lightbox.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section-md">
    <div class="gallery-container">
      <div class="gallery-grid" id="gallery">
        {landscapeImages.map((img, i) => (
          <button
            class="gallery-item"
            data-index={i}
            data-src={asset(img.src)}
            data-alt={img.alt}
            aria-label={`View larger: ${img.alt}`}
          >
            <img src={asset(img.src)} alt={img.alt} width={img.width} height={img.height} loading="lazy" />
            <div class="gallery-item-overlay">
              <span class="gallery-item-label">{img.alt}</span>
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>


  {/* ══ LIGHTBOX (no edits needed) ════════════════════════════════════ */}
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <button class="lightbox-close" id="lb-close" aria-label="Close">✕</button>
    <button class="lightbox-nav lightbox-prev" id="lb-prev" aria-label="Previous">‹</button>
    <div class="lightbox-inner">
      <img class="lightbox-img" id="lb-img" src="" alt="" />
    </div>
    <button class="lightbox-nav lightbox-next" id="lb-next" aria-label="Next">›</button>
    <div class="lightbox-counter" id="lb-counter"></div>
  </div>


  {/* ══ PORTRAIT CROSSLINK ════════════════════════════════════════════
      Links back to portrait work. Uses second portrait image.
      To hide: wrap the <section> in {/* ... *\/}
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section bg-strong">
    <div class="container">
      <div class="split">
        <div>
          <span class="eyebrow">Portrait work</span>
          <h2 style="margin-top: var(--space-3);">The same eye, applied to people</h2>
          <p style="margin-top: var(--space-4);">
            The observational sensibility behind this landscape and abstract work is
            exactly what I bring to portrait sessions — attention to light, atmosphere,
            and the authentic moment.
          </p>
          <div class="btn-row" style="margin-top: var(--space-6);">
            <a href={route('portfolio/portraits/')} class="btn btn-primary">Portrait gallery</a>
            <a href={route('sessions/')}            class="btn btn-outline">Sessions from $350</a>
          </div>
        </div>
        <div class="split-image">
          <img src={asset(portraitImages[1].src)} alt={portraitImages[1].alt} width={portraitImages[1].width} height={portraitImages[1].height} loading="lazy" />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .gallery-container { padding-inline: 2px; }
  .portfolio-nav { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .landscape-hero { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); align-items: stretch; }
  .landscape-hero-wide { border-radius: var(--radius-lg); overflow: hidden; aspect-ratio: 3 / 4; }
  .landscape-hero-wide img { width: 100%; height: 100%; object-fit: cover; }
  .landscape-hero-pair { display: flex; flex-direction: column; gap: var(--space-3); }
  .lh-pair-item { flex: 1; min-height: 0; overflow: hidden; border-radius: var(--radius-lg); }
  .lh-pair-item img { width: 100%; height: 100%; object-fit: cover; display: block; }

  @media (max-width: 768px) {
    .landscape-hero { grid-template-columns: 1fr; }
    .landscape-hero-wide { aspect-ratio: 16/9; }
    .landscape-hero-pair { flex-direction: row; }
    .lh-pair-item { aspect-ratio: 1; }
  }
</style>

<script>
  const items = document.querySelectorAll<HTMLButtonElement>('.gallery-item');
  const lightbox = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbClose = document.getElementById('lb-close')!;
  const lbPrev = document.getElementById('lb-prev')!;
  const lbNext = document.getElementById('lb-next')!;
  const lbCounter = document.getElementById('lb-counter')!;

  let current = 0;
  const images = Array.from(items).map(el => ({ src: el.dataset.src!, alt: el.dataset.alt! }));

  function open(i: number) { current = i; show(); lightbox.classList.add('is-open'); document.body.style.overflow = 'hidden'; }
  function close() { lightbox.classList.remove('is-open'); document.body.style.overflow = ''; }
  function show() { lbImg.src = images[current].src; lbImg.alt = images[current].alt; lbCounter.textContent = `${current + 1} / ${images.length}`; }
  function prev() { current = (current - 1 + images.length) % images.length; show(); }
  function next() { current = (current + 1) % images.length; show(); }

  items.forEach((btn, i) => btn.addEventListener('click', () => open(i)));
  lbClose.addEventListener('click', close);
  lbPrev.addEventListener('click', prev);
  lbNext.addEventListener('click', next);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) close(); });
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('is-open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') prev();
    if (e.key === 'ArrowRight') next();
  });
</script>
