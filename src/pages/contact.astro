---
import BaseLayout from '../layouts/BaseLayout.astro';
import { asset, route } from '../lib/paths';
import { site, pricing } from '../content/data';

// ─── Availability widget ─────────────────────────────────────────────────────
// Computed at build time from the deploy date. Shows "next month & month after",
// which matches typical portrait booking lead times (4–8 weeks out).
//
// To override manually (e.g. "Away until September", "Fully booked — waitlist only"),
// set `manualAvailability` to a non-empty string. Leave empty to auto-compute.
// If you override, remember to clear the string again after, or rebuild to reset.
//
// The site needs to rebuild for the automatic value to roll forward — set up a
// scheduled rebuild (e.g. Cloudflare Pages / Netlify monthly cron) if you want
// this to stay current without manual pushes.
const manualAvailability = '';

const now = new Date();
const monthFormat = new Intl.DateTimeFormat('en-US', { month: 'long' });
const nextMonth = new Date(now.getFullYear(), now.getMonth() + 1, 1);
const monthAfter = new Date(now.getFullYear(), now.getMonth() + 2, 1);
const autoAvailability = `Currently booking ${monthFormat.format(nextMonth)} & ${monthFormat.format(monthAfter)} sessions`;

const availabilityText = manualAvailability || autoAvailability;
---

<BaseLayout
  title="Contact"
  description={`Book a portrait session with ${site.name} — Lafayette, IN and Urbana-Champaign, IL. Get in touch to discuss your brief, ask questions, or reserve a date.`}
>

  {/* ══ PAGE HEADER ══════════════════════════════════════════════════ */}
  <section class="page-header">
    <div class="container">
      <span class="eyebrow">Contact</span>
      <h1>Let's talk</h1>
      <p class="lead" style="margin-top: var(--space-4); max-width: 48ch;">
        Tell me what you have in mind and I'll get back to you within a day or two.
      </p>
    </div>
  </section>


  {/* ══ CONTACT FORM + SIDEBAR ════════════════════════════════════════
      HubSpot form embed (portal 245952972, form 9f5b63ee-...).
      Session pre-population: links pass ?session_type= which HubSpot
      reads automatically and populates the hidden session_type field.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <div class="contact-layout">

        <div>
          <h3 style="margin-bottom: var(--space-6);">Send a message</h3>
          <div class="hs-form-frame" data-region="na2" data-form-id="9f5b63ee-d630-48ff-9a62-ecbaa7726cd5" data-portal-id="245952972"></div>
        </div>

        <aside class="contact-sidebar stack-lg">
          <div>
            <h5 style="margin-bottom: var(--space-4);">Direct contact</h5>
            <div class="stack-sm">
              <a href={`mailto:${site.email}`} class="contact-link">
                <span class="contact-link-icon">✉</span>
                <span>{site.email}</span>
              </a>
              <a href={site.instagramUrl} target="_blank" rel="noopener noreferrer" class="contact-link">
                <span class="contact-link-icon">◎</span>
                <span>@{site.instagram}</span>
              </a>
            </div>
          </div>
          <div class="divider"></div>
          <div>
            <h5 style="margin-bottom: var(--space-4);">Based in</h5>
            <p class="muted" style="font-size: var(--text-sm);">{site.location}</p>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              Available within 30 miles of Lafayette and Urbana-Champaign at standard rates.
              {pricing.travel.indianapolis.label} +${pricing.travel.indianapolis.fee} ·
              {pricing.travel.chicago.label} +${pricing.travel.chicago.fee}
            </p>
          </div>
          <div class="divider"></div>
          <div>
            {/* ── Availability — auto-computed from build date ─────────────────
                Shows "next month & month after". To override manually (holiday,
                waitlist, fully booked), set `manualAvailability` in the
                frontmatter at the top of this file.
            ────────────────────────────────────────────────────────────────── */}
            <div class="availability-signal">
              <span class="availability-dot" aria-hidden="true"></span>
              <span>{availabilityText}</span>
            </div>
          </div>
          <div class="divider"></div>
          <div>
            <h5 style="margin-bottom: var(--space-4);">Good to know</h5>
            <ul class="checklist">
              <li>I reply within 1–2 business days</li>
              <li>I'm happy to answer questions before you commit</li>
              <li>Rescheduling is always possible</li>
            </ul>
          </div>
        </aside>

      </div>
    </div>
  </section>


  {/* ══ QUICK FAQ ════════════════════════════════════════════════════
      Two high-anxiety questions surfaced before someone commits to contact.
      Full FAQ lives on the sessions page.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section-md bg-soft">
    <div class="container container-narrow">
      <h4 style="margin-bottom: var(--space-6);">Before you write</h4>
      <div class="quick-faq">
        <div class="quick-faq-item">
          <h6>Do I need experience in front of a camera?</h6>
          <p>
            No. Most people feel awkward — that's normal, and part of the job is helping
            you past it. We take our time. By the end of the session you'll have forgotten
            the camera is there.
          </p>
        </div>
        <div class="quick-faq-item">
          <h6>What if the weather doesn't cooperate?</h6>
          <p>
            We reschedule at no cost. Weather happens — I'd rather get the session right
            than push through conditions that don't serve the work.
          </p>
        </div>
      </div>
      <p style="margin-top: var(--space-6); font-size: var(--text-sm); color: var(--color-muted);">
        More questions? <a href={route('sessions/')} style="color: var(--color-accent); text-decoration: underline; text-underline-offset: 2px;">See the full FAQ on the sessions page.</a>
      </p>
    </div>
  </section>


  {/* ══ PHOTO STRIP ═══════════════════════════════════════════════════
      4 portrait thumbnails at the bottom. Change filenames to swap images.
      To hide: wrap the section in {/* ... *\/}
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section-sm bg-strong">
    <div class="container">
      <div class="contact-gallery">
        <div class="contact-gallery-item"><img src={asset('portrait/portrait-8.jpg')} alt="Portrait — man in athletic jacket, industrial window behind him" width="2000" height="1330" loading="lazy" /></div>
        <div class="contact-gallery-item"><img src={asset('portrait/portrait-9.jpg')} alt="Portrait — man by window, laughing, looking down" width="2000" height="1330" loading="lazy" /></div>
        <div class="contact-gallery-item"><img src={asset('portrait/baby.jpg')}       alt="Portrait — child's hands on a ukulele, close crop" width="2000" height="1334" loading="lazy" /></div>
        <div class="contact-gallery-item"><img src={asset('portrait/portrait-5.jpg')} alt="Portrait — woman leaning by window, smiling" width="1330" height="2000" loading="lazy" /></div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .contact-layout { display: grid; grid-template-columns: 1fr 320px; gap: var(--space-10); align-items: start; }
  .contact-form { width: 100%; }
  .contact-sidebar { position: sticky; top: 6rem; background: var(--color-surface-soft); border-radius: var(--radius-lg); padding: var(--space-7); }
  .contact-link { display: flex; align-items: center; gap: var(--space-3); font-family: var(--font-sans); font-size: var(--text-sm); color: var(--color-fg); padding: var(--space-3); border-radius: var(--radius); text-decoration: none; transition: background var(--transition); }
  .contact-link:hover { background: var(--color-surface-strong); }
  .contact-link-icon { width: 2rem; height: 2rem; display: flex; align-items: center; justify-content: center; background: var(--color-surface-strong); border-radius: var(--radius); font-size: var(--text-base); flex-shrink: 0; }
  .checklist { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); }
  .checklist li { display: flex; align-items: flex-start; gap: var(--space-3); font-size: var(--text-sm); color: var(--color-muted); }
  .checklist li::before { content: "–"; color: var(--color-accent); flex-shrink: 0; font-family: var(--font-sans); }
  .quick-faq { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-7); }
  .quick-faq-item h6 { margin-bottom: var(--space-3); font-family: var(--font-sans); font-size: var(--text-sm); font-weight: 500; }
  .quick-faq-item p { font-size: var(--text-sm); color: var(--color-muted); }
  @media (max-width: 600px) { .quick-faq { grid-template-columns: 1fr; gap: var(--space-5); } }
  .availability-signal { display: flex; align-items: center; gap: var(--space-3); font-family: var(--font-sans); font-size: var(--text-sm); color: var(--color-fg); font-weight: 500; }
  .availability-dot { width: 8px; height: 8px; border-radius: 50%; background: #5a9a6e; flex-shrink: 0; box-shadow: 0 0 0 3px rgba(90,154,110,0.2); }
  .contact-gallery { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-3); }
  .contact-gallery-item { aspect-ratio: 3 / 4; overflow: hidden; border-radius: var(--radius-lg); }
  .contact-gallery-item img { width: 100%; height: 100%; object-fit: cover; display: block; }

  @media (max-width: 900px) {
    .contact-layout { grid-template-columns: 1fr; }
    .contact-sidebar { position: static; }
    .contact-gallery { grid-template-columns: repeat(2, 1fr); }
    .contact-gallery-item:nth-child(n+3) { display: none; }
  }
</style>

<script src="https://js-na2.hsforms.net/forms/embed/245952972.js" defer></script>
