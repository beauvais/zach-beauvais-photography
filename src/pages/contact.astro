---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<BaseLayout
  title="Contact | Zach Beauvais Photographer"
  description="Book a portrait session with Zach Beauvais Photographer in Lafayette, Indiana."
  path="/contact/"
>
  <section class="section page-hero">
    <div class="container stack">
      <SectionHeading
        eyebrow="Contact / booking"
        title="Tell me what you want the images to do."
        intro="The best sessions start with a conversation. Send a message and we'll talk through what you're after before anything is confirmed."
      />

      <div class="contact-grid">
        <article class="contact-card stack">
          <h3>Get in touch</h3>
          <p>
            Email is the best way to reach me for booking enquiries. Instagram DMs work too.
          </p>
          <div class="button-row">
            <a class="button button-primary" href="mailto:zach@zachbeauvais.com?subject=Portrait%20session%20enquiry">Email Zach</a>
            <a class="button button-secondary" href="https://instagram.com/zach_of_the" target="_blank" rel="noopener noreferrer">Message on Instagram</a>
          </div>
        </article>

        <article class="note-card stack">
          <h3>Helpful details to include</h3>
          <ul class="location-list">
            <li>Which package interests you (1-hour or 3-hour)</li>
            <li>Preferred location and city</li>
            <li>Approximate timing or date</li>
            <li>Whether the session is personal, professional, or art-led</li>
            <li>Any visual references or ideas you have in mind</li>
          </ul>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
