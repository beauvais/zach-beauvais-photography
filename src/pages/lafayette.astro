---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/sections/CTABand.astro';
import { asset, route } from '../lib/paths';
import { pricing, portraitImages } from '../content/data';

const faqData = [
  {
    q: "Where do Lafayette and West Lafayette sessions take place?",
    a: "Wherever fits the portrait — the Wabash Heritage Trail, downtown Lafayette, industrial areas near the river, spots around the Purdue campus. We talk it through first, then I'll suggest locations based on what you're after."
  },
  {
    q: "Is parking straightforward in Lafayette and West Lafayette?",
    a: "Generally yes. Street parking in both downtown Lafayette and the West Lafayette/Purdue area is usually easy to manage. I'll suggest locations with that in mind."
  },
  {
    q: "I'm at Purdue — can we do the session on campus?",
    a: "Yes. Purdue has some good architecture and interesting light. I'd suggest working around peak busy periods, but we can sort that out when we're planning."
  }
];

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Zach Beauvais Photography",
  "description": "Portrait photography in Lafayette and West Lafayette, Indiana. Collaborative sessions for individuals, families, and small businesses.",
  "url": "https://zachbeauvais.com/lafayette/",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Lafayette",
    "addressRegion": "IN",
    "addressCountry": "US"
  },
  "areaServed": ["Lafayette", "West Lafayette", "Central Indiana", "Northern Indiana"],
  "priceRange": "$350–$750"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a }
  }))
};

const schema = JSON.stringify([localBusiness, faqSchema]);
---

<BaseLayout
  title="Portrait Photographer in Lafayette & West Lafayette, Indiana"
  description="Portrait photography in Lafayette and West Lafayette, Central Indiana — from $350. Collaborative sessions for Purdue students, faculty, families, and anyone not interested in cornfield-at-sunset photos."
  schema={schema}
>

  {/* ══ PAGE HEADER ══════════════════════════════════════════════════ */}
  <section class="page-header">
    <div class="container">
      <span class="eyebrow">Portrait photographer</span>
      <h1>Lafayette &amp; West Lafayette, Indiana.</h1>
      <p class="lead" style="margin-top: var(--space-4); max-width: 52ch;">
        Collaborative portrait photography for people in Lafayette, West Lafayette, and the wider
        Purdue community — from personal brand work to family portraits to sessions that are just
        for you.
      </p>
    </div>
  </section>


  {/* ══ THE APPROACH ══════════════════════════════════════════════════
      Split: text left, portrait right.
      [16] woman-pillar — colour, concrete pillar — fits "industrial space" line.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section bg-strong">
    <div class="container">
      <div class="approach-split">
        <div class="stack">
          <p>
            Indiana has a particular kind of portrait photographer. Golden hour, open fields,
            soft focus — beautiful work, and a lot of people do it well. I'm not that photographer.
          </p>
          <p>
            A session with me starts with a conversation about what you're actually after — what the
            photos are for, what you want them to say, what kind of person you want to look like in
            them. Then we find a location that fits, and we work from there.
          </p>
          <p>
            The Midwest has good light and nature. It also has concrete, brick, and industrial space
            that nobody thinks to photograph in. I like both.
          </p>
        </div>
        <div class="approach-image">
          <img
            src={asset(portraitImages[16].src)}
            alt={portraitImages[16].alt}
            width={portraitImages[16].width}
            height={portraitImages[16].height}
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>


  {/* ══ WHO THIS IS FOR ═══════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <span class="eyebrow">Good for</span>
      <h2>Boilermakers, Hoosiers, and everyone else</h2>
      <div class="who-grid">
        <p>
          I work with people building a brand or professional presence — social media, LinkedIn,
          personal sites — families or couples who want portraits that feel like them rather than
          like a template, and people who just want to see what a proper portrait session produces
          when there's no agenda.
        </p>
        <p>
          If you're at Purdue — student, faculty, researcher, or staff — I've made a lot of
          portraits for people who need something better than a faculty page headshot.
        </p>
        <p>
          Outside the university: Lafayette and West Lafayette have families, small businesses,
          and individuals who want portraits made with some care. That's the same work, same
          approach, same result.
        </p>
      </div>
    </div>
  </section>


  {/* ══ PHOTO STRIP ═══════════════════════════════════════════════════
      Three portraits showing range: individual, couple, personal.
      [5]  man-floor          — individual, relaxed
      [20] couple-colour      — couple
      [14] woman-curly-window — personal, expressive
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section-sm bg-strong">
    <div class="container">
      <div class="strip-masonry">
        <div class="strip-masonry-item">
          <a
            href={asset(portraitImages[5].src)}
            data-pswp-width={portraitImages[5].width}
            data-pswp-height={portraitImages[5].height}
            data-pswp-id={portraitImages[5].src.split('/').pop()?.replace(/\.[^.]+$/, '').toLowerCase()}
            class="pswp-thumb"
          >
            <img
              src={asset(portraitImages[5].src)}
              alt={portraitImages[5].alt}
              width={portraitImages[5].width}
              height={portraitImages[5].height}
              loading="lazy"
            />
          </a>
        </div>
        <div class="strip-masonry-item">
          <a
            href={asset(portraitImages[20].src)}
            data-pswp-width={portraitImages[20].width}
            data-pswp-height={portraitImages[20].height}
            data-pswp-id={portraitImages[20].src.split('/').pop()?.replace(/\.[^.]+$/, '').toLowerCase()}
            class="pswp-thumb"
          >
            <img
              src={asset(portraitImages[20].src)}
              alt={portraitImages[20].alt}
              width={portraitImages[20].width}
              height={portraitImages[20].height}
              loading="lazy"
            />
          </a>
        </div>
        <div class="strip-masonry-item">
          <a
            href={asset(portraitImages[14].src)}
            data-pswp-width={portraitImages[14].width}
            data-pswp-height={portraitImages[14].height}
            data-pswp-id={portraitImages[14].src.split('/').pop()?.replace(/\.[^.]+$/, '').toLowerCase()}
            class="pswp-thumb"
          >
            <img
              src={asset(portraitImages[14].src)}
              alt={portraitImages[14].alt}
              width={portraitImages[14].width}
              height={portraitImages[14].height}
              loading="lazy"
            />
          </a>
        </div>
      </div>
    </div>
  </section>


  {/* ══ SESSIONS ══════════════════════════════════════════════════════ */}
  <section class="section bg-soft">
    <div class="container">
      <span class="eyebrow">Sessions &amp; Pricing</span>
      <h2>Two sessions. Editing always included.</h2>
      <p class="lead" style="margin-top: var(--space-4); max-width: 52ch;">
        Standard rates apply for Lafayette, West Lafayette, and anywhere within 30 miles.
        No travel fee.
      </p>

      <div class="grid-2" style="margin-top: var(--space-7);">

        <div class="pricing-card">
          <div>
            <h6>{pricing.essential.name}</h6>
            <div class="pricing-amount" style="margin-top: var(--space-4);">
              <span>$</span>{pricing.essential.price}
            </div>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              One hour, one location, five edited portraits. Good for professional images, personal
              brand work, milestones, or a gift.
            </p>
          </div>
          <ul class="pricing-features">
            <li>One hour at a single location</li>
            <li>5 professionally edited portraits</li>
            <li>High-resolution digital delivery</li>
            <li>All editing included</li>
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/?session_type=essential')} class="btn btn-outline">
              Book the {pricing.essential.name.toLowerCase()}
            </a>
          </div>
        </div>

        <div class="pricing-card featured">
          <div>
            <h6>{pricing.extended.name}</h6>
            <div class="pricing-amount" style="margin-top: var(--space-4);">
              <span>$</span>{pricing.extended.price}
            </div>
            <p class="muted" style="font-size: var(--text-sm); margin-top: var(--space-3);">
              Three hours, one location, twenty edited portraits. More time means the session
              can find what it needs to — good for couples, families, or anything that
              needs to be worked out rather than executed.
            </p>
          </div>
          <ul class="pricing-features">
            <li>Three hours at a single location</li>
            <li>20 professionally edited portraits</li>
            <li>High-resolution digital delivery</li>
            <li>All editing included</li>
          </ul>
          <div class="pricing-footer">
            <a href={route('contact/?session_type=exploration')} class="btn btn-primary">
              Book the {pricing.extended.name.toLowerCase()}
            </a>
          </div>
        </div>

      </div>

      <p class="bespoke-note">
        Need something bigger or different — multiple locations, ongoing brand work, a larger
        selection? <a href={route('contact/?session_type=bespoke')}>Get in touch</a> and we'll scope it together.
      </p>
    </div>
  </section>


  {/* ══ FAQ ═══════════════════════════════════════════════════════════ */}
  <section class="section">
    <div class="container">
      <span class="eyebrow">Questions</span>
      <h2>A few things people ask</h2>
      <div class="faq-list">
        <div class="faq-item">
          <p class="faq-q">{faqData[0].q}</p>
          <p class="faq-a">{faqData[0].a}</p>
        </div>
        <div class="faq-item">
          <p class="faq-q">{faqData[1].q}</p>
          <p class="faq-a">{faqData[1].a}</p>
        </div>
        <div class="faq-item">
          <p class="faq-q">{faqData[2].q}</p>
          <p class="faq-a">{faqData[2].a}</p>
        </div>
      </div>
    </div>
  </section>


  {/* ══ CTA ═══════════════════════════════════════════════════════════ */}
  <CTABand
    eyebrow="Based in Lafayette"
    heading="Get in touch"
    body="Let's talk about what you're thinking — what the photos are for, what you want them to do, what you're unsure about. We'll figure out the rest from there."
    primaryHref={route('contact/')}
    primaryLabel="Get in touch"
    secondaryHref={route('sessions/')}
    secondaryLabel="See sessions & pricing"
  />

</BaseLayout>

<style>
.pswp-thumb { display: block; }
</style>

<script type="module">
  import PhotoSwipeLightbox from 'https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe-lightbox.esm.min.js';

  const lightbox = new PhotoSwipeLightbox({
    gallery: document.body,
    children: 'a[data-pswp-width]',
    pswpModule: () => import('https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.esm.min.js'),
    history: false,
  });

  lightbox.on('afterInit', () => {
    const pswp = lightbox.pswp;
    const setHash = () => {
      const id = pswp.currSlide?.data.element?.dataset.pswpId;
      if (id) history.replaceState(null, '', `#${id}`);
    };
    pswp.on('change', setHash);
    setHash();
    pswp.on('destroy', () => {
      history.replaceState(null, '', location.pathname + location.search);
    });
  });

  lightbox.init();

  const hash = location.hash.slice(1);
  if (hash) {
    const links = Array.from(document.querySelectorAll('a[data-pswp-width]'));
    const index = links.findIndex(a => a.dataset.pswpId === hash);
    if (index !== -1) lightbox.loadAndOpen(index);
  }
</script>

