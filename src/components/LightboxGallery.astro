---
interface Item {
  src: string;
  alt: string;
}

const { items } = Astro.props as { items: Item[] };
---

<section class="lightbox-gallery">
  <div class="portfolio-grid">
    {items.map((item, index) => (
      <button
        class="lightbox-thumb"
        type="button"
        data-lightbox-open
        data-index={index}
        data-src={item.src}
        data-alt={item.alt}
        aria-label={`Open image ${index + 1}`}
      >
        <img src={item.src} alt={item.alt} loading="lazy" />
      </button>
    ))}
  </div>

  <dialog class="lightbox-dialog" data-lightbox-dialog>
    <button class="lightbox-close" type="button" data-lightbox-close aria-label="Close image">
      ×
    </button>

    <button class="lightbox-prev" type="button" data-lightbox-prev aria-label="Previous image">
      ‹
    </button>

    <figure class="lightbox-figure">
      <img data-lightbox-image src="" alt="" />
    </figure>

    <button class="lightbox-next" type="button" data-lightbox-next aria-label="Next image">
      ›
    </button>
  </dialog>
</section>

<script define:vars={{ items }}>
  const dialog = document.querySelector('[data-lightbox-dialog]');
  const image = document.querySelector('[data-lightbox-image]');
  const openButtons = document.querySelectorAll('[data-lightbox-open]');
  const closeButton = document.querySelector('[data-lightbox-close]');
  const prevButton = document.querySelector('[data-lightbox-prev]');
  const nextButton = document.querySelector('[data-lightbox-next]');

  let currentIndex = 0;

  const showImage = (index) => {
    currentIndex = index;
    const item = items[currentIndex];
    if (!item || !image) return;
    image.src = item.src;
    image.alt = item.alt;
  };

  openButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const index = Number(button.getAttribute('data-index') || 0);
      showImage(index);
      dialog?.showModal();
    });
  });

  closeButton?.addEventListener('click', () => dialog?.close());

  prevButton?.addEventListener('click', () => {
    const nextIndex = currentIndex === 0 ? items.length - 1 : currentIndex - 1;
    showImage(nextIndex);
  });

  nextButton?.addEventListener('click', () => {
    const nextIndex = currentIndex === items.length - 1 ? 0 : currentIndex + 1;
    showImage(nextIndex);
  });

  dialog?.addEventListener('click', (event) => {
    const rect = dialog.getBoundingClientRect();
    const isInside =
      rect.top <= event.clientY &&
      event.clientY <= rect.top + rect.height &&
      rect.left <= event.clientX &&
      event.clientX <= rect.left + rect.width;

    if (!isInside) dialog.close();
  });
</script>