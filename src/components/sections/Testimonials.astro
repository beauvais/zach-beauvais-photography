---
// ─── Testimonials ───────────────────────────────────────────────────────────
// Filler quotes — replace with real client testimonials when available.
// Usage:
//   <Testimonials />                    → homepage set (4 quotes, 2-col)
//   <Testimonials variant="sessions" /> → sessions set (2 quotes, 2-col)
//   <Testimonials variant="about" />    → about set (2 quotes, 2-col)
//
// To replace filler: edit the quote arrays below. Keep quotes specific.
// Avoid: "amazing", "incredible", "passionate", generic praise.

type Variant = 'homepage' | 'sessions' | 'about';

interface Props {
  variant?: Variant;
}

interface Testimonial {
  quote: string;
  name: string;
  context: string;
}

const { variant = 'homepage' } = Astro.props;

// ── All filler testimonials ────────────────────────────────────────────────
const all: Record<Variant, Testimonial[]> = {
  homepage: [
    {
      quote: "I had such a great time shooting with Zach. He provided a comfortable environment and we were able to collaborate on the creative process of the photos. Super happy with how the pictures came out!",
      name: "Lydia",
      context: "Personal session",
    },
    {
      quote: "Zach really helped me shine. It was comfortable, casual, and professional. He's the kind of photographer I'd want to work with over and over.",
      name: "Alex",
      context: "Non-profit branding",
    },
  ],
  sessions: [
    {
      quote: "Zach really helped me shine. It was comfortable, casual, and professional. He’s the kind of photographer I’d want to work with over and over.",
      name: "Alex",
      context: "Non-profit branding"
    }
  ],
  about: [],
};

const testimonials = all[variant];

if (testimonials.length === 0) {
  return null;
}
---

<section class="section testimonials-section">
  <div class="container">
    <div class="section-header" style="margin-bottom: var(--space-8);">
      <span class="eyebrow">From clients</span>
      <h2>What people say.</h2>
    </div>
    <div class="testimonials-grid">
      {testimonials.map(t => (
        <blockquote class="testimonial-card">
          <span class="quote-mark" aria-hidden="true">&ldquo;</span>
          <p class="quote-text">{t.quote}</p>
          <footer class="quote-attribution">
            <span class="quote-name">{t.name}</span>
            <span class="quote-context">{t.context}</span>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    background: var(--color-surface-soft);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }

  .testimonial-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-7) var(--space-6) var(--space-6);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .quote-mark {
    position: absolute;
    top: var(--space-4);
    left: var(--space-5);
    font-family: var(--font-serif);
    font-size: 4rem;
    line-height: 1;
    color: var(--color-accent);
    opacity: 0.5;
    pointer-events: none;
    user-select: none;
  }

  .quote-text {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: 1.65;
    color: var(--color-fg);
    padding-top: var(--space-4);
    flex: 1;
  }

  .quote-attribution {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
  }

  .quote-name {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-fg);
  }

  .quote-context {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>