---
const base = import.meta.env.BASE_URL;
const root = base.endsWith('/') ? base : `${base}/`;

const navItems = [
  { href: root, label: 'Home' },
  { href: `${root}portraits/`, label: 'Sessions' },
  { href: `${root}portfolio/collaborative/`, label: 'Portraits' },
  { href: `${root}portfolio/landscape/`, label: 'Landscape' },
  { href: `${root}about/`, label: 'About' },
  { href: `${root}pricing/`, label: 'Pricing' },
  { href: `${root}contact/`, label: 'Contact' }
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brandmark" href={root}>
      <span class="brandmark-monogram" aria-hidden="true">ZB</span>
      <span class="brandmark-text">
        <span class="brandmark-name">Zach Beauvais</span>
        <span class="brandmark-tag">Photographer</span>
      </span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul>
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>