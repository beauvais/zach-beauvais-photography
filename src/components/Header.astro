---
const navItems = [
  { href: `${import.meta.env.BASE_URL}`, label: 'Home' },
  { href: `${import.meta.env.BASE_URL}portraits/`, label: 'Portrait Sessions' },
  { href: `${import.meta.env.BASE_URL}portfolio/collaborative/`, label: 'Collaborative Portraits' },
  { href: `${import.meta.env.BASE_URL}portfolio/landscape/`, label: 'Landscape & Abstract' },
  { href: `${import.meta.env.BASE_URL}about/`, label: 'About' },
  { href: `${import.meta.env.BASE_URL}contact/`, label: 'Contact' }
];
---

---

<header class="site-header">
  <div class="container header-inner">
    <a class="brandmark" href="/">
      <span class="brandmark-monogram" aria-hidden="true">ZB</span>
      <span class="brandmark-text">
        <span class="brandmark-name">Zach Beauvais</span>
        <span class="brandmark-tag">Photographer</span>
      </span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul>
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>
