---
import { route } from '../lib/paths';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner container">
    <div class="footer-brand">
      <a href={route('/')} class="footer-logo" aria-label="Zach Beauvais Photography">
        <span class="footer-monogram">ZB</span>
      </a>
      <p class="footer-tagline">
        Collaborative portrait photography<br />
        rooted in storytelling and art.
      </p>
      <nav class="footer-brand-links">
        <a href={route('contact/')}>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Contact
        </a>
        <a href="https://instagram.com/zach_of_the" target="_blank" rel="noopener noreferrer">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/></svg>
          Instagram
        </a>
        <a href="mailto:zach@zachbeauvais.com">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Email
        </a>
      </nav>
    </div>

    <div class="footer-links">
      <div class="footer-col">
        <h6>Work</h6>
        <nav>
          <a href={route('portfolio/')}>Portfolio</a>
          <a href={route('portfolio/portraits/')}>Portraits</a>
          <a href={route('portfolio/landscape/')}>Landscape &amp; Art</a>
        </nav>
      </div>

      <div class="footer-col">
        <h6>Info</h6>
        <nav>
          <a href={route('sessions/')}>Sessions &amp; Pricing</a>
          <a href={route('how-i-work/')}>How I work</a>
          <a href={route('about/')}>About</a>
        </nav>
      </div>

      <div class="footer-col">
        <h6>For</h6>
        <nav>
          <a href={route('non-profit-branding/')}>Non-profit branding</a>
        </nav>
      </div>

      <div class="footer-col">
        <h6>Locations</h6>
        <nav>
          <a href={route('lafayette/')}>Lafayette, Indiana</a>
          <a href={route('urbana-champaign/')}>Urbana-Champaign, IL</a>
          <a href={route('indianapolis/')}>Indianapolis</a>
          <a href={route('chicago/')}>Chicago</a>
        </nav>
      </div>
    </div>
  </div>

  <div class="footer-bottom container">
    <p class="muted">&copy; {year} Zach Beauvais. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-9);
    padding-bottom: var(--space-6);
    margin-top: auto;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer-logo {
    display: inline-flex;
    text-decoration: none;
  }

  .footer-monogram {
    width: 3rem;
    height: 3rem;
    background: var(--color-primary);
    color: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
  }

  .footer-tagline {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-fg);
    max-width: none;
  }

  .footer-location {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    max-width: none;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  .footer-col h6 { margin-bottom: var(--space-4); }

  .footer-col nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-col nav a {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-col nav a:hover { color: var(--color-fg); }

  .footer-brand-links {
    display: flex;
    flex-direction: row;
    gap: var(--space-5);
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .footer-brand-links a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-brand-links a:hover { color: var(--color-fg); }

  .footer-bottom { padding-top: var(--space-5); }
  .footer-bottom p { font-family: var(--font-sans); font-size: var(--text-xs); max-width: none; }

  @media (max-width: 900px) {
    .footer-links { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .footer-links { grid-template-columns: 1fr; }
  }
</style>
