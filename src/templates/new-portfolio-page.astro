---
// ═════════════════════════════════════════════════════════════════════
// NEW PORTFOLIO PAGE TEMPLATE
//
// HOW TO USE:
//   1. Copy this file to src/pages/portfolio/your-category.astro
//   2. Add your images to src/content/data.ts (new export or reuse existing)
//   3. Import that export below and replace `myImages`
//   4. Update title, description, heading, and intro text
//   5. Add a nav link in src/components/Header.astro if needed
//
// ADDING IMAGES:
//   In src/content/data.ts, add a new export:
//
//   export const eventImages = [
//     { src: 'event-01.jpg', alt: 'Description' },
//     { src: 'event-02.jpg', alt: 'Description' },
//   ];
//
//   Then import it here: import { eventImages } from '../../content/data';
//   And replace `myImages` with `eventImages`.
// ═════════════════════════════════════════════════════════════════════

import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABand from '../../components/sections/CTABand.astro';
import { asset, route } from '../../lib/paths';

// Replace with your actual image import from data.ts
// import { eventImages as myImages } from '../../content/data';

// Placeholder — remove this when you add your real import above
const myImages = [
  { src: 'Woman-monochrome-intense-kind.jpg', alt: 'Placeholder — replace with your images' },
];
---

<BaseLayout
  title="Portfolio — Category Name"
  description="Description of this portfolio category."
>

  {/* ══ PAGE HEADER ══════════════════════════════════════════════════ */}
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumb">
        <a href={route('portfolio/')}>Portfolio</a>
        <span class="breadcrumb-sep">/</span>
        <span>Category Name</span>
      </nav>
      <h1>Category Heading</h1>
      <p class="lead" style="margin-top: var(--space-4); max-width: 52ch;">
        One or two sentences describing this body of work.
      </p>
      {/* Portfolio sub-navigation — update active button to match this page */}
      <div class="portfolio-nav" style="margin-top: var(--space-6);">
        <a href={route('portfolio/')}           class="btn btn-outline btn-sm">All work</a>
        <a href={route('portfolio/portraits/')} class="btn btn-outline btn-sm">Portraits</a>
        <a href={route('portfolio/landscape/')} class="btn btn-outline btn-sm">Landscape &amp; Art</a>
        <a href="#"                             class="btn btn-primary btn-sm">This Category</a>
      </div>
    </div>
  </section>


  {/* ══ OPTIONAL INTRO TEXT ═══════════════════════════════════════════
      Remove or comment out if you don't want text before the gallery.
  ══════════════════════════════════════════════════════════════════ */}
  {/*
  <section class="section-sm bg-soft">
    <div class="container-narrow">
      <h2 style="margin-bottom: var(--space-4);">About this work</h2>
      <p>Describe the work in this category.</p>
    </div>
  </section>
  */}


  {/* ══ GALLERY ═══════════════════════════════════════════════════════
      Renders all images from myImages. Click opens the lightbox.
      No changes needed here — add/remove images via data.ts.
  ══════════════════════════════════════════════════════════════════ */}
  <section class="section-md">
    <div class="gallery-container">
      <div class="gallery-grid" id="gallery">
        {myImages.map((img, i) => (
          <button
            class="gallery-item"
            data-index={i}
            data-src={asset(img.src)}
            data-alt={img.alt}
            aria-label={`View larger: ${img.alt}`}
          >
            <img src={asset(img.src)} alt={img.alt} loading="lazy" />
            <div class="gallery-item-overlay">
              <span class="gallery-item-label">{img.alt}</span>
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>


  {/* ══ LIGHTBOX — do not edit ════════════════════════════════════════ */}
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <button class="lightbox-close" id="lb-close" aria-label="Close">✕</button>
    <button class="lightbox-nav lightbox-prev" id="lb-prev" aria-label="Previous">‹</button>
    <div class="lightbox-inner">
      <img class="lightbox-img" id="lb-img" src="" alt="" />
    </div>
    <button class="lightbox-nav lightbox-next" id="lb-next" aria-label="Next">›</button>
    <div class="lightbox-counter" id="lb-counter"></div>
  </div>


  {/* ══ CTA ═══════════════════════════════════════════════════════════ */}
  <CTABand
    eyebrow="Book a session"
    heading="Like what you see?"
    body="Sessions from $350. Let's discuss your portrait."
    primaryHref={route('contact/')}
    primaryLabel="Get in touch"
    secondaryHref={route('sessions/')}
    secondaryLabel="See pricing"
  />

</BaseLayout>

<style>
  .gallery-container { padding-inline: 2px; }
  .portfolio-nav { display: flex; flex-wrap: wrap; gap: var(--space-2); }
</style>

<script>
  const items = document.querySelectorAll<HTMLButtonElement>('.gallery-item');
  const lightbox = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbClose = document.getElementById('lb-close')!;
  const lbPrev = document.getElementById('lb-prev')!;
  const lbNext = document.getElementById('lb-next')!;
  const lbCounter = document.getElementById('lb-counter')!;

  let current = 0;
  const images = Array.from(items).map(el => ({ src: el.dataset.src!, alt: el.dataset.alt! }));

  function open(i: number) { current = i; show(); lightbox.classList.add('is-open'); document.body.style.overflow = 'hidden'; }
  function close() { lightbox.classList.remove('is-open'); document.body.style.overflow = ''; }
  function show() { lbImg.src = images[current].src; lbImg.alt = images[current].alt; lbCounter.textContent = `${current + 1} / ${images.length}`; }
  function prev() { current = (current - 1 + images.length) % images.length; show(); }
  function next() { current = (current + 1) % images.length; show(); }

  items.forEach((btn, i) => btn.addEventListener('click', () => open(i)));
  lbClose.addEventListener('click', close);
  lbPrev.addEventListener('click', prev);
  lbNext.addEventListener('click', next);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) close(); });
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('is-open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') prev();
    if (e.key === 'ArrowRight') next();
  });
</script>
